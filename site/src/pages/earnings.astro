---
import fs from 'node:fs';
import path from 'node:path';

const root = process.cwd().endsWith('site') ? path.resolve(process.cwd(), '..') : process.cwd();
const dataPath = path.join(root, 'site/public/data/quant-audit.json');
if (!fs.existsSync(dataPath)) throw new Error(`Missing generated model data: ${dataPath}`);
const model = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
const apiPath = path.join(root, 'site/public/api/v1/index.json');
if (!fs.existsSync(apiPath)) throw new Error('Missing primary facts API: ' + apiPath);
const primaryApi = JSON.parse(fs.readFileSync(apiPath, 'utf8'));
const snapshot = model.snapshot;
const consensus = snapshot.consensus;
const base = import.meta.env.BASE_URL;

const pct = (value, digits = 1) => `${Number(value) >= 0 ? '+' : ''}${Number(value).toFixed(digits)}%`;
const pct0 = (value) => `${Number(value) >= 0 ? '+' : ''}${(Number(value) * 100).toFixed(1)}%`;
const bn = (value) => `$${Number(value).toFixed(1)}B`;
const range = (values) => `${pct(values[0])} → ${pct(values[1])}`;
const titleCase = (value) => value.charAt(0).toUpperCase() + value.slice(1);
const severityLabel = { critical: 'CRITICAL', major: 'MAJOR', minor: 'MINOR' };
const verdictLabel = { conditional: 'CONDITIONAL', supported: 'SUPPORTED', blocked: 'BLOCKED' };
const verdictJa = { conditional: '条件付き妥当', supported: '支持', blocked: '保留' };
const consensusMargin = consensus.forward_margin * (1 + consensus.operating_earnings_growth_2027) / (1 + consensus.revenue_growth_2027);
const modelRows = model.scenarios.map((scenario) => ({
  ...scenario,
  label: titleCase(scenario.name),
  earnings: range(scenario.operating_earnings_growth_range),
  revenue: range(scenario.revenue_growth_range),
  barLeft: Math.max(0, Math.min(100, (scenario.revenue_growth_range[0] + 30) * 0.8)),
  barWidth: Math.max(4, Math.min(100, (scenario.revenue_growth_range[1] - scenario.revenue_growth_range[0]) * 0.8)),
}));
const baseScenario = modelRows.find((scenario) => scenario.name === 'base') || modelRows[0];
const sources = snapshot.sources;
const openFindings = model.audit.findings.filter((finding) => finding.status === 'open');
const scenarioInputs = snapshot.scenarios;
const baseInput = scenarioInputs.find((scenario) => scenario.name === 'base') || scenarioInputs[0];
const formatDecimalPct = (value) => (Number(value) >= 0 ? '+' : '') + (Number(value) * 100).toFixed(0) + '%';
const inputKind = { fact: 'FACT', definition: 'DEFINITION', assumption: 'ASSUMPTION', output: 'OUTPUT' };
const sourceWalks = sources.map((source) => ({
  ...source,
  residual: Number(source.operating_cash_flow) - Number(source.capital_expenditures),
}));
const primaryFacts = primaryApi.companies.flatMap((company) => company.facts);
const coverageLabel = {
  reported_facts_same_period: 'AGGREGATED',
  public_no_10q_facts_yet: 'PUBLIC / AWAITING 10-Q',
  capital_expenditure_fact_unavailable: 'PUBLIC / CAPEX MISSING',
  excluded_without_estimate: 'PRIVATE / NO PUBLIC FACTS',
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="一次資料のスナップショットから再計算する、半導体市場の決算モデル。" />
    <title>決算モデル / Signal Room</title>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <main class="shell">
      <header class="topbar">
        <a class="brand" href={base}><span class="brand-dot"></span>KAFKA / MODEL ROOM</a>
      <nav aria-label="ページ内ナビゲーション">
          <a href="#guide">読み方</a>
          <a href="#raw-data">原データ</a>
          <a href="#coverage">API</a>
          <a href="#scenarios">シナリオ</a>
          <a href="#evidence">証拠</a>
          <a href="#method">モデル定義</a>
        </nav>
      </header>

      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow"><span class="pulse"></span> EARNINGS MODEL / VERSIONED SNAPSHOT</p>
          <h1>数字が変わるたび、<em>前提</em>から更新する。</h1>
          <p class="dek">ハイパースケーラーのキャッシュ創出、半導体コンセンサス、利益率を同じ入力スナップショットから再計算する。予言ではなく、更新できる監査面。</p>
        </div>
        <aside class="hero-stamp">
          <div class="stamp-ring"><span>Q</span><strong>01</strong></div>
          <div><span class="micro">GRAPH VERSION</span><b>{snapshot.graph_version}</b></div>
          <div><span class="micro">SNAPSHOT</span><b>{snapshot.as_of}</b></div>
          <div><span class="micro">STATE</span><b class="state">{verdictLabel[model.audit.verdict] || model.audit.verdict}</b></div>
        </aside>
      </section>

      <section class="kpi-grid" aria-label="主要指標">
        <article class="kpi kpi-accent"><span>2027 consensus / revenue</span><strong>{pct0(consensus.revenue_growth_2027)}</strong><small>Yardeni · {consensus.as_of}</small></article>
        <article class="kpi"><span>2027 consensus / operating earnings</span><strong>{pct0(consensus.operating_earnings_growth_2027)}</strong><small>margin implies {pct0(consensusMargin)}</small></article>
        <article class="kpi"><span>base case / earnings range</span><strong>{range(baseScenario.operating_earnings_growth_range).replace(' → ', '—')}</strong><small>β = {snapshot.beta_range[0]}—{snapshot.beta_range[1]}</small></article>
        <article class="kpi"><span>capital expenditures / operating CF</span><strong>{(model.normalized.capital_expenditures_to_operating_cash_flow * 100).toFixed(1)}%</strong><small>{bn(model.normalized.capital_expenditures_total)} / {bn(model.normalized.operating_cash_flow_total)}</small></article>
      </section>

      <section class="signal-strip" aria-label="判定">
        <div class="signal-led"><span class="signal-mark">!</span><div><span class="micro">MODEL VERDICT</span><strong>{verdictJa[model.audit.verdict] || model.audit.verdict}</strong></div></div>
        <p>{pct0(consensus.operating_earnings_growth_2027)}は強気レンジに入る。ただし、βは未推定、投資のラグは未実装、公開一次データで比較可能な銘柄だけを集計。</p>
        <span class="confidence">confidence {Math.round(model.audit.confidence * 100)}%</span>
      </section>

      <section id="guide" class="guide-section">
        <div class="section-heading guide-heading">
          <div><p class="eyebrow">00 / HOW TO READ</p><h2>このページの読み方</h2></div>
          <span class="section-meta">FACT → ASSUMPTION → OUTPUT</span>
        </div>
        <div class="guide-lead">
          <p class="guide-question">問いはひとつ。</p>
          <h3>半導体の営業利益 <strong>{pct0(consensus.operating_earnings_growth_2027)}</strong> は、どんな前提なら成立するか。</h3>
          <p>左から右へ読むと、元の決算数値がどの式を通り、どこで仮定になり、最後にどの監査項目が残るかが分かります。</p>
        </div>
        <ol class="guide-path">
          <li class="guide-step"><span class="step-no">01</span><span class="kind fact">{inputKind.fact}</span><h3>決算から拾う</h3><p>同じ四半期の10-Qから、営業CFとcapital expendituresのXBRL factを読む。</p></li>
          <li class="guide-step"><span class="step-no">02</span><span class="kind definition">{inputKind.definition}</span><h3>期間とタグを揃える</h3><p>同じperiod_start / period_end、報告されたfact tagだけを合計する。</p></li>
          <li class="guide-step"><span class="step-no">03</span><span class="kind output">{inputKind.output}</span><h3>投資負担を測る</h3><p>{bn(model.normalized.capital_expenditures_total)} ÷ {bn(model.normalized.operating_cash_flow_total)} = {(model.normalized.capital_expenditures_to_operating_cash_flow * 100).toFixed(1)}%。一次情報の足し算から比率を出す。</p></li>
          <li class="guide-step"><span class="step-no">04</span><span class="kind assumption">{inputKind.assumption}</span><h3>未来の仮定を置く</h3><p>OCF成長、残すFCF、借入・リース、β、利益率をシナリオごとに置く。</p></li>
          <li class="guide-step"><span class="step-no">05</span><span class="kind output">{inputKind.output}</span><h3>結果を監査する</h3><p>売上成長→営業利益成長へ変換し、未推定のβや投資ラグをOPENとして残す。</p></li>
        </ol>
        <div class="legend" aria-label="表示区分">
          <span><i class="legend-dot fact"></i>確認できる事実</span>
          <span><i class="legend-dot definition"></i>定義・集計方法</span>
          <span><i class="legend-dot assumption"></i>モデルの仮定</span>
          <span><i class="legend-dot output"></i>計算結果</span>
        </div>
      </section>

      <section id="raw-data" class="raw-data-section">
        <div class="section-heading">
          <div><p class="eyebrow">00.1 / RAW DATA</p><h2>数字の出発点</h2></div>
          <a class="raw-link" href={base + 'data/quant-audit.json'}>raw snapshot ↗</a>
        </div>
        <p class="section-intro">ここにある数字がモデルの入力です。営業CFも設備投資も、SEC EDGAR Companyfactsに登録された10-Qの報告値です。推定値を足さず、リンク先の一次資料とfact tagを確認できます。</p>
        <div class="raw-table-wrap">
          <table class="raw-table">
            <caption>2026年3月期 / USD billions</caption>
            <thead><tr><th scope="col">Company</th><th scope="col">Period</th><th scope="col">Operating CF</th><th scope="col">Capital expenditures</th><th scope="col">SEC fact tag</th><th scope="col">Source</th></tr></thead>
            <tbody>
              {sources.map((source) => (
                <tr><th scope="row">{source.label}</th><td>{source.period_end}</td><td class="number fact-number">{bn(source.operating_cash_flow)}</td><td class="number fact-number">{bn(source.capital_expenditures)}</td><td><span class="definition-text">{source.capital_expenditures_fact_tag}</span></td><td><a class="table-link" href={source.source_url} target="_blank" rel="noreferrer">10-Q ↗</a></td></tr>
              ))}
            </tbody>
            <tfoot><tr><th scope="row">Total / reported facts</th><td>—</td><td class="number">{bn(model.normalized.operating_cash_flow_total)}</td><td class="number">{bn(model.normalized.capital_expenditures_total)}</td><td colspan="2">same-period group</td></tr></tfoot>
          </table>
        </div>
        <div class="data-note"><span class="kind definition">{inputKind.definition}</span><p>会社ごとにXBRL fact tagは異なりますが、ここでは各社が報告したcapital expendituresの値をそのまま表示します。期間が揃わないOracleや、標準capex tagがまだ取れないDigital Realtyは、下の合計へ混ぜません。</p></div>
      </section>

      <section id="coverage" class="coverage-section">
        <div class="section-heading">
          <div><p class="eyebrow">00.15 / PRIMARY API</p><h2>誰を、どこまで測れるか</h2></div>
          <a class="raw-link" href={base + 'api/v1/index.json'}>API index ↗</a>
        </div>
        <p class="section-intro">母集団を増やすほど良い、とは限りません。一次factが存在し、同じ期間で2項目そろう会社だけを集計し、残りは「欠測」として表示します。</p>
        <div class="coverage-stats">
          <div><span>REGISTERED ENTITIES</span><strong>{primaryApi.companies.length}</strong></div>
          <div><span>PRIMARY FACTS</span><strong>{primaryFacts.length}</strong></div>
          <div><span>IN AGGREGATE</span><strong>{sources.length}</strong></div>
          <div><span>EXCLUDED / NO ESTIMATE</span><strong>{primaryApi.companies.length - sources.length}</strong></div>
        </div>
        <div class="coverage-table-wrap">
          <table class="coverage-table">
            <caption>Entity registry / status is data, not a forecast</caption>
            <thead><tr><th scope="col">Entity</th><th scope="col">Role</th><th scope="col">Status</th><th scope="col">Facts</th><th scope="col">Latest filing</th></tr></thead>
            <tbody>
              {primaryApi.companies.map((company) => (
                <tr class={company.quantitative_status === 'reported_facts_same_period' ? 'included' : 'excluded'}>
                  <th scope="row">{company.name}{company.product_aliases ? <small> ({company.product_aliases.join(', ')})</small> : ''}</th>
                  <td>{company.role}</td>
                  <td><span class="status-label">{coverageLabel[company.quantitative_status] || company.quantitative_status}</span></td>
                  <td class="number">{company.facts.length}</td>
                  <td>{company.recent_filings?.[0] ? <a class="table-link" href={company.recent_filings[0].source_url} target="_blank" rel="noreferrer">{company.recent_filings[0].form} / {company.recent_filings[0].filed} ↗</a> : '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section id="company-ledger" class="company-section">
        <div class="section-heading">
          <div><p class="eyebrow">00.2 / COMPANY LEDGER</p><h2>銘柄ごとの決算ウォーク</h2></div>
          <span class="section-meta">ONE COMPANY → ONE CONTRIBUTION</span>
        </div>
        <p class="section-intro">集計の前に、各社を1行ずつ見ます。ここでの「差額」はフリーキャッシュフローそのものではなく、報告された営業CFから報告された設備投資を引いただけの残差です。</p>
        <div class="company-grid">
          {sourceWalks.map((source, index) => (
            <article class="company-card">
              <header><span class="source-index">0{index + 1}</span><div><h3>{source.label}</h3><span>{source.period_end} / 10-Q</span></div><a href={source.source_url} target="_blank" rel="noreferrer">一次資料 ↗</a></header>
              <div class="company-inputs">
                <div><span>営業CF</span><strong>{bn(source.operating_cash_flow)}</strong><small>本業から生んだ現金</small></div>
                <div class="operator">−</div>
                <div><span>capital expenditures</span><strong>{bn(source.capital_expenditures)}</strong><small>SEC tag: {source.capital_expenditures_fact_tag}</small></div>
              </div>
              <div class="company-result"><span>2項目の残差</span><strong>{bn(source.residual)}</strong><small>{source.residual >= 0 ? '投資後に残る' : '営業CFを上回る'}（OCF − capital expenditures）</small></div>
              <details><summary>この銘柄の読み方</summary><p>10-Qで営業CFと設備投資のXBRL fact tagを別々に確認し、このカードの2つの報告値を同じperiodで加算します。推定capexやリース推計はこの合計に入れていません。</p></details>
            </article>
          ))}
        </div>
      </section>

      <section id="scenarios" class="section-block">
        <div class="section-heading"><div><p class="eyebrow">01 / SCENARIO MAP</p><h2>利益成長の地形</h2></div><div class="filterbar"><button class="filter active" data-filter="all">ALL CASES</button>{modelRows.map((row) => <button class="filter" data-filter={row.name}>{row.label.toUpperCase()}</button>)}</div></div>
        <div class="scenario-frame">
          <div class="axis"><span>−30%</span><span>0</span><span>+30%</span><span>+60%</span></div>
          {modelRows.map((row) => (
            <article class={`scenario-row ${row.name}`} data-scenario={row.name}>
              <div class="scenario-name"><span class="scenario-pin"></span><b>{row.label}</b><small>investment {pct(row.effective_investment_growth)}</small></div>
              <div class="range-track" aria-label={`${row.label} revenue range`}><span class="range-bar" style={`left:${row.barLeft}%;width:${row.barWidth}%`}></span><i class="zero-line"></i></div>
              <div class="scenario-values"><strong>{row.earnings}</strong><small>earnings</small><span>{row.revenue} rev.</span></div>
            </article>
          ))}
        </div>
        <div class="target-note"><span>MARKET TARGET</span><b>{pct0(consensus.operating_earnings_growth_2027)} operating earnings</b><span>only overlaps the bull case</span></div>
      </section>

      <section id="evidence" class="section-block">
        <div class="section-heading"><div><p class="eyebrow">02 / EVIDENCE LEDGER</p><h2>資金はどこから来るか</h2></div><span class="section-meta">Q1 2026 / USD billions</span></div>
        <div class="evidence-grid">
          {sources.map((source) => (
            <article class="evidence-card">
              <div class="evidence-top"><span class="source-index">0{sources.indexOf(source) + 1}</span><h3>{source.label}</h3><a href={source.source_url} target="_blank" rel="noreferrer">10-Q ↗</a></div>
                <div class="evidence-numbers"><div><span>OPERATING CF</span><strong>{bn(source.operating_cash_flow)}</strong></div><div><span>CAPITAL EXPENDITURES</span><strong>{bn(source.capital_expenditures)}</strong></div></div>
              <p><span class="definition-dot"></span>{source.capital_expenditures_fact_tag}</p>
            </article>
          ))}
        </div>
        <div class="evidence-total"><div><span class="micro">REPORTED OCF</span><strong>{bn(model.normalized.operating_cash_flow_total)}</strong></div><div class="math-sign">−</div><div><span class="micro">REPORTED CAPEX</span><strong>{bn(model.normalized.capital_expenditures_total)}</strong></div><div class="math-sign">=</div><div class="total-result"><span class="micro">RESIDUAL</span><strong>{bn(model.normalized.residual_cash_flow)} <small>({(model.normalized.residual_margin * 100).toFixed(1)}%)</small></strong></div></div>
        <p class="footnote">※ 合計は同じperiod_start / period_endと、SECのprimary fact tagを持つ銘柄だけ。6社の報告値を足した機械的な集計で、業界全体の設備投資推定ではありません。</p>
      </section>

      <section class="audit-grid">
        <div class="section-heading compact"><div><p class="eyebrow">03 / AUDIT GATE</p><h2>未解決の前提</h2></div><span class="section-meta">{openFindings.length} OPEN FINDINGS</span></div>
        <div class="finding-list">
          {openFindings.map((finding) => (
            <div class="finding"><span class={`severity ${finding.severity}`}>{severityLabel[finding.severity]}</span><div><b>{finding.id.replaceAll('_', ' ')}</b><p>{finding.detail}</p></div><span class="open-dot"></span></div>
          ))}
        </div>
      </section>

      <section id="equations" class="equations-section">
        <div class="section-heading">
          <div><p class="eyebrow">03.1 / FROM CASH TO GROWTH</p><h2>足す、割る、掛ける。</h2></div>
          <span class="section-meta">BASE CASE WORKED EXAMPLE</span>
        </div>
        <div class="equation-layout">
          <article class="equation-card">
            <span class="kind definition">{inputKind.definition}</span>
            <h3>まず、投資に使える力を出す</h3>
            <code>gI = (1 + gOCF) × (1 − mFCF + f) / r₀ − 1</code>
            <p>営業CFが伸び、そのうちFCFとして残す分と外部資金を除いた「投資に回せる力」を、現在の投資負担率で割ります。</p>
            <div class="variable-grid">
              <div><code>r₀</code><span>現在のcapital expenditures / OCF</span><b>{(model.normalized.capital_expenditures_to_operating_cash_flow * 100).toFixed(1)}%</b></div>
              <div><code>gOCF</code><span>営業CF成長</span><b>{formatDecimalPct(baseInput.ocf_growth)}</b></div>
              <div><code>mFCF</code><span>残すFCF</span><b>{formatDecimalPct(baseInput.fcf_reserve)}</b></div>
              <div><code>f</code><span>外部資金</span><b>{formatDecimalPct(baseInput.external_financing)}</b></div>
            </div>
            <div class="worked-example"><span>BASE CASE / 数字を代入</span><code>(1 + {formatDecimalPct(baseInput.ocf_growth)}) × (1 − {formatDecimalPct(baseInput.fcf_reserve)} + {formatDecimalPct(baseInput.external_financing)}) / {(model.normalized.capital_expenditures_to_operating_cash_flow).toFixed(2)} − 1 = <b>{pct(baseScenario.effective_investment_growth)}</b></code></div>
          </article>
          <article class="equation-card">
            <span class="kind output">{inputKind.output}</span>
            <h3>次に、投資を売上と利益へ移す</h3>
            <code>gR = β × gI</code>
            <code>gE = (1 + gR) × (M₁ / M₀) − 1</code>
            <p>βは「投資成長が売上に伝わる強さ」。最後に利益率が変わる分を加えます。今回はβ = {snapshot.beta_range[0]}—{snapshot.beta_range[1]}を仮定し、ベースでは利益率を{pct0(baseInput.forward_margin)}で据え置きます。</p>
            <div class="worked-example"><span>BASE CASE / βを掛ける</span><code>({snapshot.beta_range[0]}—{snapshot.beta_range[1]}) × {pct(baseScenario.effective_investment_growth)} = <b>{range(baseScenario.revenue_growth_range)}</b></code></div>
            <div class="worked-example"><span>利益率が同じなら</span><code>(1 + gR) × ({pct0(baseInput.forward_margin)} / {pct0(consensus.forward_margin)}) − 1 = <b>{range(baseScenario.operating_earnings_growth_range)}</b></code></div>
          </article>
        </div>
        <div class="assumption-heading"><p class="eyebrow">INPUTS / SCENARIO TABLE</p><h3>結果の前に置いた仮定</h3><p>ここは決算から直接読んだ事実ではなく、モデルが置いた未来の条件です。</p></div>
        <div class="assumption-grid">
          {scenarioInputs.map((scenario) => (
            <article class="assumption-card">
              <div><span class="scenario-pin"></span><h3>{titleCase(scenario.name)}</h3></div>
              <dl>
                <div><dt>OCF growth</dt><dd>{formatDecimalPct(scenario.ocf_growth)}</dd></div>
                <div><dt>FCF reserve</dt><dd>{formatDecimalPct(scenario.fcf_reserve)}</dd></div>
                <div><dt>External financing</dt><dd>{formatDecimalPct(scenario.external_financing)}</dd></div>
                <div><dt>Forward margin</dt><dd>{formatDecimalPct(scenario.forward_margin)}</dd></div>
              </dl>
            </article>
          ))}
        </div>
        <div class="consensus-box"><span class="kind assumption">{inputKind.assumption}</span><p><strong>市場コンセンサス</strong> 2027 revenue {pct0(consensus.revenue_growth_2027)} / operating earnings {pct0(consensus.operating_earnings_growth_2027)} / forward margin {pct0(consensus.forward_margin)}。出所は{consensus.source}の二次情報で、企業自身の一次予想ではありません。</p></div>
      </section>

      <section id="method" class="method-grid">
        <div class="method-intro"><p class="eyebrow">04 / MODEL DEFINITION</p><h2>再計算できる形にする。</h2><p>LangGraphはノード遷移だけを担当し、数式は純粋関数として固定。新しい決算は既存データを上書きせず、新しいスナップショットとして取り込む。</p><a class="text-link" href={`${base}earnings/`}>snapshot hash: {model.snapshot_hash.slice(0, 12)}… ↗</a></div>
        <div class="formula-card"><span class="micro">CORE EQUATIONS</span><code>gI = (1 + gOCF) × (1 − mFCF + f) / {snapshot.model_base_ratio} − 1</code><code>gR = β × gI</code><code>gE = (1 + gR) × (M1 / {pct0(consensus.forward_margin)}) − 1</code><div class="protocol"><span>UPDATE PROTOCOL</span><b>new snapshot → validate → normalize → calculate → audit → publish</b></div></div>
      </section>

      <footer class="footer"><span>MODEL ROOM / built from versioned evidence</span><span>not investment advice · status remains conditional</span></footer>
    </main>
    <script>
      const buttons = document.querySelectorAll('[data-filter]');
      const rows = document.querySelectorAll('[data-scenario]');
      buttons.forEach((button) => button.addEventListener('click', () => {
        buttons.forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        const filter = button.dataset.filter;
        rows.forEach((row) => { row.hidden = filter !== 'all' && row.dataset.scenario !== filter; });
      }));
    </script>
