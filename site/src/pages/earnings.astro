---
import fs from 'node:fs';
import path from 'node:path';

const root = process.cwd().endsWith('site') ? path.resolve(process.cwd(), '..') : process.cwd();
const model = JSON.parse(fs.readFileSync(path.join(root, 'site/public/data/quant-audit.json'), 'utf8'));
const primaryApi = JSON.parse(fs.readFileSync(path.join(root, 'site/public/api/v1/index.json'), 'utf8'));
const profitApi = JSON.parse(fs.readFileSync(path.join(root, 'site/public/api/v1/semiconductor-profit/index.json'), 'utf8'));
const snapshot = model.snapshot;
const normalized = model.normalized;
const sources = snapshot.sources;
const findings = model.audit.findings;
const base = import.meta.env.BASE_URL;
const buildSha = import.meta.env.PUBLIC_BUILD_SHA;
if (!buildSha) throw new Error('PUBLIC_BUILD_SHA is required for provenance');

const usd = (value) => `$${(Number(value) / 1_000_000_000).toFixed(3)}B`;
const exactUsd = (value) => `$${Number(value).toLocaleString('en-US')} USD`;
const dateJP = (value) => {
  const [year, month, day] = value.slice(0, 10).split('-').map(Number);
  return `${year}年${month}月${day}日`;
};
const periodLabel = `${dateJP(snapshot.primary_period.start)}〜${dateJP(snapshot.primary_period.end)}`;
const cohortIds = new Set(sources.map((source) => source.id));
const profitCompanies = profitApi.companies.filter((company) => company.quarters.length > 0);
const profitHistoryQuarters = Math.min(...profitCompanies.map((company) => company.quarters.length));
const latestProfit = (company) => company.quarters[0];
const previousYearQuarter = (company) => {
  const current = latestProfit(company);
  if (current?.fiscal_year == null || current?.fiscal_period == null) return null;
  return company.quarters.find((quarter) => quarter.fiscal_year === current.fiscal_year - 1 && quarter.fiscal_period === current.fiscal_period) || null;
};
const yoyIncome = (company) => {
  const current = latestProfit(company)?.operating_income.reported_value;
  const previous = previousYearQuarter(company)?.operating_income.reported_value;
  if (current == null || previous == null || previous === 0) return null;
  return (Number(current) / Number(previous) - 1) * 100;
};
const chartHeight = (company, value) => {
  const max = Math.max(...company.quarters.map((quarter) => Math.abs(Number(quarter.operating_income.reported_value))), 1);
  return Math.max(3, Math.round(Math.abs(Number(value)) / max * 100));
};
const pct = (value) => `${value >= 0 ? '+' : ''}${value.toFixed(1)}%`;
const capexTagCount = normalized.capital_expenditures_fact_tag_count;
const capexIsComparable = capexTagCount === 1;
const capexSummary = capexIsComparable
  ? '設備投資は同じタグで揃っているため、合計を表示します。'
  : `設備投資は${capexTagCount}種類のタグに分かれるため、全社合計は計算しません。`;
const findingSummary = {
  capital_expenditure_concepts_not_comparable: `設備投資が${capexTagCount}種類のXBRLタグに分かれるため、全社の設備投資合計と残差は公開していません。`,
};

const statusCopy = {
  reported_facts_same_period: { label: '数字あり', description: '同じ四半期のOCFと設備投資を確認' },
  public_no_10q_facts_yet: { label: '10-Q待ち', description: '公開企業だが、まだ10-Qのfactなし' },
  public_no_quarterly_10q_facts: { label: '四半期数字なし', description: '公開資料に対象factなし' },
  capital_expenditure_fact_unavailable: { label: '設備投資なし', description: '設備投資factが未取得' },
  operating_cash_flow_fact_unavailable: { label: '営業CFなし', description: '営業CF factが未取得' },
  reported_facts_period_mismatch: { label: '期間不一致', description: '2つの数字が同じ四半期ではない' },
  excluded_without_estimate: { label: '公開数字なし', description: '非公開企業のため推定しない' },
};
for (const company of primaryApi.companies) {
  if (!(company.quantitative_status in statusCopy)) throw new Error(`Unknown quantitative status: ${company.quantitative_status}`);
}
const sourceFor = (source) => source.operating_cash_flow_source_url;
const companyApiFor = (source) => `${base}api/v1/companies/${source.id}.json`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="決算資料から、AI投資を支える会社の営業キャッシュフローと設備投資を一次情報で読む。" />
    <title>決算の読み方 / 一次情報台帳</title>
  </head>
  <body>
    <main class="page">
      <header class="topbar">
        <a class="brand" href={base} aria-label="トップへ戻る"><span class="brand-mark">＋</span><span>決算の読み方<span class="brand-sub"> / PRIMARY FACTS</span></span></a>
        <nav aria-label="ページ内ナビゲーション">
          <a href="#how">読み方</a>
          <a href="#profit">利益推移</a>
          <a href="#companies">会社別</a>
          <a href="#limits">注意点</a>
        </nav>
      </header>

      <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="kicker"><span class="live-dot"></span>30秒でわかる決算データ</p>
          <h1 id="page-title"><span>半導体企業の利益が、</span><em>どこまで伸びているか。</em></h1>
          <p class="hero-lede">半導体企業自身の売上高と営業利益を、SECに提出された決算factから5年分追います。データセンター投資は、その利益につながる需要側の補助線として別に読みます。</p>
          <div class="hero-actions">
            <a class="button button-primary" href="#how">まず読み方を見る <span>↓</span></a>
            <a class="button button-quiet" href="#profit">利益を見る <span>→</span></a>
          </div>
        </div>
        <aside class="hero-card" aria-label="今回のデータ範囲">
          <p class="card-kicker">利益factを読める範囲</p>
          <strong>{profitCompanies.length}<small>社</small></strong>
          <p>{profitHistoryQuarters}四半期以上 / 最大5年</p>
          <div class="hero-card-rule"></div>
          <span>売上高と営業利益が同じ期間で揃った会社</span>
        </aside>
      </section>

      <section id="how" class="how section-block" aria-labelledby="how-title">
        <div class="section-intro">
          <p class="section-number">01 / HOW TO READ</p>
          <h2 id="how-title">見る場所は、<br /><em>3つだけ。</em></h2>
        </div>
        <div class="how-grid">
          <article class="how-card"><span class="step">01</span><div><h3>利益を見る</h3><p>まず半導体企業の売上高と営業利益を、四半期ごとのバーで追います。</p></div></article>
          <article class="how-card"><span class="step">02</span><div><h3>需要を見る</h3><p>データセンターの営業CFと設備投資は、利益の前にある需要側の数字です。</p></div></article>
          <article class="how-card"><span class="step">03</span><div><h3>資料へ戻る</h3><p>出典からSEC提出書類へ移動し、数字の原文とXBRLタグを確認します。</p></div></article>
        </div>
      </section>

      <section class="snapshot section-block" aria-labelledby="snapshot-title">
        <div class="section-heading">
          <div><p class="section-number">02 / AT A GLANCE</p><h2 id="snapshot-title">今回の全体像</h2></div>
          <span class="period-chip">{periodLabel}</span>
        </div>
        <div class="snapshot-grid">
          <article class="snapshot-card snapshot-card-main"><span>同じ期間で読める会社</span><strong>{sources.length}<small>社</small></strong><p>この期間の営業CFと設備投資が、一次資料で揃っています。</p></article>
          <article class="snapshot-card"><span>営業CFの単純合計</span><strong>{usd(normalized.operating_cash_flow_total_usd)}</strong><p>同じXBRLタグの報告値を足したものです。</p></article>
          <article class="snapshot-card"><span>設備投資の扱い</span><strong>{capexTagCount}<small>種類のタグ</small></strong><p>{capexSummary}</p></article>
        </div>
        <div class="boundary-note"><span class="note-icon">i</span><p><strong>ここで分かるのは「事実」と「足し算」まで。</strong> 未来の利益、株価、コンセンサス予想は、この台帳には含めていません。</p></div>
      </section>

      <section id="profit" class="profit section-block" aria-labelledby="profit-title">
        <div class="section-heading">
          <div><p class="section-number">03 / PROFIT THROUGH TIME</p><h2 id="profit-title">半導体企業の<br /><em>利益推移。</em></h2></div>
          <a class="outline-link" href={profitApi.target.index_url} target="_blank" rel="noreferrer">SOXの定義を見る <span>↗</span></a>
        </div>
        <p class="section-lede">バーは各社の営業利益です。会社ごとに最大値を100として、約5年の増減を形で見せています。会社の会計期末が違うため、異なる期間を合算した「指数利益」は表示しません。</p>
        <div class="profit-bridge">
          <div><span>直接読める企業</span><strong>{profitCompanies.length}<small>社</small></strong><p>売上高＋営業利益</p></div>
          <div><span>履歴</span><strong>{profitHistoryQuarters}<small>四半期以上</small></strong><p>最大20四半期を保存</p></div>
          <div><span>共通期間</span><strong>{profitApi.cohort.status === 'unique' ? '成立' : '未成立'}</strong><p>{profitApi.cohort.status === 'unique' ? '同じ期間だけ集計可能' : '異なる期間を合算しない'}</p></div>
        </div>
        <div class="time-view-head"><div><span class="section-number">TIME VIEW / OPERATING INCOME</span><h3>四半期ごとのバーを見る</h3></div><span class="chart-legend"><i></i>営業利益　<i class="legend-negative"></i>赤字</span></div>
        <div class="profit-chart-grid">
          {profitCompanies.map((company) => (
            <article class="profit-chart-card">
              <header><div><h3>{company.name}</h3><p>{company.ticker} · {company.role}</p></div><strong>{usd(latestProfit(company).operating_income.reported_value)}</strong></header>
              <p class="profit-yoy">{yoyIncome(company) === null ? '前年同期比較は計算不可' : `前年同期比 ${pct(yoyIncome(company))}`}</p>
              <div class="bar-chart" role="img" aria-label={`${company.name}の営業利益、過去${company.quarters.length}四半期`}>
                <div class="bar-zero"></div>
                {company.quarters.slice().reverse().map((quarter, index) => {
                  const value = Number(quarter.operating_income.reported_value);
                  return <div class="bar-column"><div class:list={['bar-value', value < 0 ? 'negative' : 'positive']} style={`--bar-size:${chartHeight(company, value)}%`} title={`${quarter.period_end} 営業利益 ${exactUsd(value)}`}></div><small>{index % 4 === 0 || index === company.quarters.length - 1 ? quarter.period_end.slice(0, 7) : ''}</small></div>;
                })}
              </div>
              <div class="profit-chart-foot"><span>売上高 {usd(latestProfit(company).revenue.reported_value)}</span><a href={`${base}api/v1/semiconductor-profit/companies/${company.id}.json`}>fact API ↗</a></div>
            </article>
          ))}
        </div>
      </section>

      <section id="companies" class="companies section-block" aria-labelledby="companies-title">
        <div class="section-heading">
          <div><p class="section-number">04 / DEMAND SIDE</p><h2 id="companies-title">需要側を会社別に見る</h2></div>
          <a class="outline-link" href={`${base}api/v1/index.json`}>データ一覧を開く <span>↗</span></a>
        </div>
        <p class="section-lede">カードの数字は同じ四半期の報告値です。会社ごとに出典が違うので、まとめて比較する前に1社ずつ確認できます。</p>
        <div class="company-grid">
          {sources.map((source, index) => (
            <article class="company-card">
              <header class="company-head">
                <span class="company-index">{String(index + 1).padStart(2, '0')}</span>
                <div><h3>{source.label}</h3><p>{source.ticker} · {dateJP(source.period_end)}時点</p></div>
                <span class="verified-badge">確認済み</span>
              </header>
              <div class="company-values">
                <div><span>営業CF</span><strong>{usd(source.operating_cash_flow_usd)}</strong><small>入ったお金</small></div>
                <div><span>設備投資</span><strong>{usd(source.capital_expenditures_usd)}</strong><small>使ったお金</small></div>
              </div>
              <div class="company-foot"><a href={sourceFor(source)} target="_blank" rel="noreferrer">SEC提出書類を見る <span>↗</span></a><a href={companyApiFor(source)}>この会社のAPI <span>→</span></a></div>
              <details class="raw-details"><summary>タグと正確な値を表示</summary><dl><dt>営業CF tag</dt><dd>{source.operating_cash_flow_fact_tag}</dd><dt>設備投資 tag</dt><dd>{source.capital_expenditures_fact_tag}</dd><dt>営業CF raw</dt><dd>{exactUsd(source.operating_cash_flow_usd)}</dd><dt>設備投資 raw</dt><dd>{exactUsd(source.capital_expenditures_usd)}</dd></dl></details>
            </article>
          ))}
        </div>
      </section>

      <section id="limits" class="limits section-block" aria-labelledby="limits-title">
        <div class="section-heading"><div><p class="section-number">05 / WHAT THIS MEANS</p><h2 id="limits-title">数字の使い方と、<em>限界。</em></h2></div></div>
        <div class="meaning-grid">
          <article class="meaning-card meaning-card-good"><span class="meaning-mark">◎</span><h3>この台帳でできること</h3><ul><li>同じ四半期の営業CFを会社別に比べる</li><li>設備投資の報告額とXBRLタグを確認する</li><li>SEC提出書類まで戻って原文を読む</li></ul></article>
          <article class="meaning-card meaning-card-limit"><span class="meaning-mark">!</span><h3>この台帳だけではできないこと</h3><ul><li>異なる設備投資タグを全社で合計する</li><li>未提出企業の数字を推定する</li><li>この数字だけで将来の利益や株価を予測する</li></ul></article>
        </div>
        {findings.length ? <div class="audit-callout"><span class="warning-icon">!</span><div><strong>今回の注意点</strong><p>{findingSummary[findings[0].id] || findings[0].detail}</p></div><a href="#technical">技術情報 <span>↓</span></a></div> : null}
      </section>

      <section class="coverage section-block" aria-labelledby="coverage-title">
        <details class="coverage-details">
          <summary><span><span class="section-number">06 / COVERAGE</span><strong id="coverage-title">対象企業をすべて見る</strong></span><span class="summary-count">{primaryApi.companies.length}社の登録状況 <b>＋</b></span></summary>
          <p class="section-lede">登録されている企業のうち、同じ期間の一次factが揃った会社だけが上のカードに入ります。欠測はゼロや推定値に変換しません。</p>
          <div class="coverage-list">
            {primaryApi.companies.map((company) => {
              const status = statusCopy[company.quantitative_status];
              const included = cohortIds.has(company.id);
              return <div class:list={['coverage-row', { included }]}><span class="coverage-name">{company.name}</span><span class="coverage-status">{included ? '今回のカードに表示' : status.label}</span><span class="coverage-desc">{included ? `${company.facts.length}件のfact / ${periodLabel}` : status.description}</span></div>;
            })}
          </div>
        </details>
      </section>

      <section id="technical" class="technical section-block" aria-labelledby="technical-title">
        <details>
          <summary><span><span class="section-number">TECHNICAL / PROVENANCE</span><strong id="technical-title">根拠データと更新情報</strong></span><span class="summary-count">開く <b>＋</b></span></summary>
          <div class="technical-grid"><div><span>データ取得</span><strong>{dateJP(snapshot.as_of)} / SEC EDGAR</strong></div><div><span>画面のbuild SHA</span><strong data-build-sha={buildSha}>{buildSha}</strong></div><div><span>snapshot hash</span><strong data-snapshot-hash={model.snapshot_hash}>{model.snapshot_hash}</strong></div><div><span>利益API hash</span><strong data-profit-api-hash={profitApi.content_hash}>{profitApi.content_hash}</strong></div><div><span>API</span><a href={`${base}api/v1/semiconductor-profit/index.json`}>半導体利益APIを開く ↗</a></div></div>
        </details>
      </section>

      <footer><span>一次資料から、意味を分けて読む。</span><span>SEC EDGAR · 投資助言ではありません</span></footer>
    </main>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { width: 100%; overflow-x: hidden; scroll-behavior: smooth; background: #f2eee5; }
  :global(body) { width: 100%; overflow-x: hidden; margin: 0; color: #17241d; background: #f2eee5; font-family: "Hiragino Sans", "Yu Gothic", sans-serif; }
  :global(a) { color: inherit; }
  :global(::selection) { color: #17241d; background: #d7fa67; }
  .page { width: calc(100% - 44px); max-width: 1160px; margin: auto; padding: 0 0 54px; }
  .topbar { display: flex; justify-content: space-between; align-items: center; min-height: 74px; border-bottom: 1px solid #c9c6bc; }
  .brand { display: flex; align-items: center; gap: 10px; color: #17241d; font: 700 .78rem "IBM Plex Mono", monospace; letter-spacing: .04em; text-decoration: none; }
  .brand-sub { color: #778077; font-weight: 400; }
  .brand-mark { display: grid; place-items: center; width: 25px; height: 25px; color: #17241d; border: 1px solid #17241d; font-size: 1rem; }
  nav { display: flex; gap: 24px; } nav a { color: #667168; font: .66rem "IBM Plex Mono", monospace; text-decoration: none; } nav a:hover, .outline-link:hover, .company-foot a:hover { color: #758f00; }
  .hero { display: grid; grid-template-columns: minmax(0, 1fr) 285px; gap: 65px; align-items: end; padding: clamp(65px, 9vw, 115px) 0 82px; }
  .kicker, .section-number, .card-kicker, .snapshot-card span, .company-values span, .company-values small, .verified-badge, .meaning-mark, .technical-grid span, footer { font-family: "IBM Plex Mono", monospace; letter-spacing: .09em; text-transform: uppercase; }
  .kicker { display: flex; align-items: center; gap: 9px; margin: 0 0 25px; color: #68766c; font-size: .63rem; }
  .live-dot { width: 8px; height: 8px; border-radius: 50%; background: #7d9700; box-shadow: 0 0 0 4px #dce8b0; }
  h1, h2, h3 { margin: 0; font-family: "Hiragino Mincho ProN", "Yu Mincho", serif; font-weight: 600; letter-spacing: -.07em; } h1 > span, h1 > em { display: block; }
  .hero-copy { width: 100%; min-width: 0; } h1 { max-width: 790px; color: #17241d; font-size: clamp(3rem, 7.2vw, 7rem); line-height: .99; overflow-wrap: anywhere; word-break: break-all; } h1 em, h2 em { color: #738d00; font-style: normal; }
  .hero-lede { width: 100%; max-width: 700px; margin: 30px 0 0; color: #55645a; font-size: 1rem; line-height: 1.9; overflow-wrap: anywhere; word-break: break-all; }
  .hero-actions { display: flex; gap: 10px; margin-top: 30px; }
  .button { display: inline-flex; gap: 14px; align-items: center; padding: 13px 17px; font: .68rem "IBM Plex Mono", monospace; text-decoration: none; transition: transform .2s ease, background .2s ease; } .button:hover { transform: translateY(-2px); } .button-primary { color: #eff6e8; background: #172d23; } .button-primary:hover { background: #294b38; } .button-quiet { color: #4d5c51; border: 1px solid #b7b9ac; }
  .hero-card { padding: 24px; color: #eef4e8; background: #172d23; box-shadow: 12px 12px 0 #d7ddbd; } .card-kicker { margin: 0 0 25px; color: #b5c5a6; font-size: .58rem; } .hero-card strong { display: block; color: #d7fa67; font: 600 5.5rem/ .85 "IBM Plex Mono", monospace; letter-spacing: -.08em; } .hero-card strong small { margin-left: 7px; color: #eef4e8; font: 1rem "Hiragino Sans", sans-serif; letter-spacing: 0; } .hero-card p:not(.card-kicker) { margin: 19px 0 0; color: #d8e2d3; font: .72rem "IBM Plex Mono", monospace; } .hero-card-rule { margin: 26px 0 13px; border-top: 1px solid #4e6c52; } .hero-card > span { color: #9eb09e; font-size: .72rem; line-height: 1.6; }
  .section-block { margin: 0 0 100px; } .section-intro, .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 24px; } .section-number { margin: 0 0 14px; color: #859086; font-size: .6rem; } h2 { color: #17241d; font-size: clamp(2.5rem, 5vw, 4.8rem); line-height: .98; } .section-lede { max-width: 730px; margin: 22px 0 28px; color: #67746a; font-size: .86rem; line-height: 1.8; }
