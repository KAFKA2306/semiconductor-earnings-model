---
import fs from 'node:fs';
import path from 'node:path';

const root = process.cwd().endsWith('site') ? path.resolve(process.cwd(), '..') : process.cwd();
const model = JSON.parse(fs.readFileSync(path.join(root, 'site/public/data/quant-audit.json'), 'utf8'));
const primaryApi = JSON.parse(fs.readFileSync(path.join(root, 'site/public/api/v1/index.json'), 'utf8'));
const snapshot = model.snapshot;
const normalized = model.normalized;
const sources = snapshot.sources;
const base = import.meta.env.BASE_URL;

const usd = (value) => `$${(Number(value) / 1_000_000_000).toFixed(3)}B`;
const wholeUsd = (value) => `$${Number(value).toLocaleString('en-US')} USD`;
const stamp = (value) => value.replace('T', ' ').replace(/\.\d+Z$/, 'Z');
const period = `${snapshot.primary_period.start} → ${snapshot.primary_period.end}`;
const cohortIds = new Set(sources.map((source) => source.id));
const statusLabel = {
  reported_facts_same_period: 'FACTS PRESENT',
  public_no_10q_facts_yet: 'PUBLIC / NO 10-Q',
  public_no_quarterly_10q_facts: 'PUBLIC / NO QUARTERLY FACT',
  capital_expenditure_fact_unavailable: 'PUBLIC / CAPEX MISSING',
  operating_cash_flow_fact_unavailable: 'PUBLIC / OCF MISSING',
  reported_facts_period_mismatch: 'PUBLIC / PERIOD MISMATCH',
  excluded_without_estimate: 'PRIVATE / NO PUBLIC FACT',
};
for (const company of primaryApi.companies) {
  if (!(company.quantitative_status in statusLabel)) throw new Error(`Unknown quantitative status: ${company.quantitative_status}`);
}
const capexGroups = Object.entries(normalized.capital_expenditures_by_fact_tag_usd);
const findings = model.audit.findings;
const sourceFor = (source, kind) => kind === 'operating_cash_flow' ? source.operating_cash_flow_source_url : source.capital_expenditures_source_url;
const factFor = (source, kind) => kind === 'operating_cash_flow' ? source.operating_cash_flow_fact_tag : source.capital_expenditures_fact_tag;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="SEC EDGARの提出書類から取得した一次財務factの観測台帳。推定値を混ぜない。" />
    <title>Primary Facts / Evidence Ledger</title>
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <a class="brand" href={base}><span class="brand-mark">＋</span>PRIMARY FACTS / 01</a>
        <nav aria-label="ページ内ナビゲーション">
          <a href="#facts">Facts</a>
          <a href="#ledger">Ledger</a>
          <a href="#coverage">Coverage</a>
          <a href="#audit">Audit</a>
        </nav>
      </header>

      <section class="hero">
        <div>
          <p class="eyebrow"><span class="live-dot"></span> OBSERVED DATA ONLY</p>
          <h1>見えた数字だけを、<em>残す。</em></h1>
          <p class="lede">これは半導体利益の予言ではない。SEC EDGARに提出された10-Qのfactを、会社・期間・タグ・提出書類つきで読むための証拠台帳です。</p>
        </div>
        <div class="hero-meta">
          <div><span>PRIMARY PERIOD</span><b>{period}</b></div>
          <div><span>API RETRIEVED</span><b>{stamp(snapshot.primary_api_generated_at)}</b></div>
          <div><span>FACT GRAPH</span><b>{model.audit.graph_version}</b></div>
          <div><span>STATE</span><b class="state">{model.audit.verdict.toUpperCase()}</b></div>
        </div>
      </section>

      <section class="truth-banner">
        <span class="seal">FACT<br />ONLY</span>
        <div><strong>数値の種類を混ぜない。</strong><p>報告値は一次資料。合計・比率は機械的な派生値。将来予測、β、コンセンサス、proxyはこの画面に置きません。</p></div>
      </section>

      <section class="metric-grid" aria-label="観測概要">
        <article><span>REGISTERED ENTITIES</span><strong>{primaryApi.companies.length}</strong><small>registry records</small></article>
        <article><span>PRIMARY FACTS</span><strong>{primaryApi.companies.reduce((total, company) => total + company.facts.length, 0)}</strong><small>SEC Companyfacts records</small></article>
        <article><span>IN COHORT</span><strong>{sources.length}</strong><small>same reported quarter</small></article>
        <article><span>Σ REPORTED OCF</span><strong>{usd(normalized.operating_cash_flow_total_usd)}</strong><small>arithmetic sum, USD</small></article>
      </section>

      <section id="facts" class="section">
        <div class="section-head"><div><p class="eyebrow">01 / RAW FACTS</p><h2>数字の出発点</h2></div><a class="text-link" href={base + 'api/v1/index.json'}>API INDEX ↗</a></div>
        <p class="intro">値は整数USDのまま保存されています。下の表示だけを読みやすく丸めています。各値から提出書類とXBRL fact tagへ直接移動できます。</p>
        <div class="table-wrap">
          <table>
            <caption>One row = one issuer / one reported quarter / two reported facts</caption>
            <thead><tr><th>Company</th><th>Period</th><th>Operating CF</th><th>Capital expenditures</th><th>Reported tags</th><th>Source</th></tr></thead>
            <tbody>
              {sources.map((source) => (
                <tr>
                  <th>{source.label}<small>{source.ticker}</small></th>
                  <td>{source.period_end}</td>
                  <td class="number">{usd(source.operating_cash_flow_usd)}</td>
                  <td class="number">{usd(source.capital_expenditures_usd)}</td>
                  <td><code>{source.operating_cash_flow_fact_tag}</code><code>{source.capital_expenditures_fact_tag}</code></td>
                  <td><a class="source-link" href={sourceFor(source, 'operating_cash_flow')} target="_blank" rel="noreferrer">10-Q ↗</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section id="ledger" class="section">
        <div class="section-head"><div><p class="eyebrow">02 / COMPANY LEDGER</p><h2>一社ずつ読む</h2></div><span class="section-note">NO ESTIMATE / NO POOLING</span></div>
        <p class="intro">会社別の差額は、営業CFからcapital expendituresを引いた算術差です。会社ごとの報告定義を超えてFCFと呼びません。</p>
        <div class="ledger-grid">
          {sources.map((source, index) => (
            <article class="ledger-card">
              <header><span class="index">{String(index + 1).padStart(2, '0')}</span><div><h3>{source.label}</h3><small>{source.ticker} / {source.period_start}—{source.period_end}</small></div><a class="source-link" href={sourceFor(source, 'capital_expenditures')} target="_blank" rel="noreferrer">SOURCE ↗</a></header>
              <div class="equation"><div><span>OPERATING CF</span><strong>{wholeUsd(source.operating_cash_flow_usd)}</strong><code>{factFor(source, 'operating_cash_flow')}</code></div><b>−</b><div><span>CAPITAL EXPENDITURES</span><strong>{wholeUsd(source.capital_expenditures_usd)}</strong><code>{factFor(source, 'capital_expenditures')}</code></div></div>
              <div class="card-foot"><span>ARITHMETIC DIFFERENCE</span><strong>{wholeUsd(Number(source.operating_cash_flow_usd) - Number(source.capital_expenditures_usd))}</strong></div>
            </article>
          ))}
        </div>
      </section>

      <section class="section derived">
        <div class="section-head"><div><p class="eyebrow">03 / DERIVED, NOT FACT</p><h2>足し算の境界線</h2></div><span class="section-note">EXPLICIT LIMIT</span></div>
        <div class="derived-grid">
          <article><span class="label">OPERATING CF</span><strong>{usd(normalized.operating_cash_flow_total_usd)}</strong><p>同一タグの報告値を合計した算術値。</p></article>
          <article><span class="label">CAPEX CONCEPTS</span><strong>{normalized.capital_expenditures_fact_tag_count}</strong><p>タグが複数あるため、capex総額と残差は公開しない。</p></article>
          <article><span class="label">TAG GROUPS</span>{capexGroups.map(([tag, value]) => <p class="tag-group"><code>{tag}</code><b>{usd(value)}</b></p>)}</article>
        </div>
      </section>

      <section id="coverage" class="section">
        <div class="section-head"><div><p class="eyebrow">04 / COVERAGE</p><h2>誰を、どこまで測れたか</h2></div><a class="text-link" href={base + 'api/v1/facts.json'}>FACTS API ↗</a></div>
        <p class="intro">対象範囲は現在のregistryとSEC取得結果の交差です。欠測はゼロや推定値に変換しません。</p>
        <div class="table-wrap">
          <table class="coverage">
            <caption>Missing is a state, never a number</caption>
            <thead><tr><th>Entity</th><th>Role</th><th>Status</th><th>Facts</th><th>Fact period</th><th>Latest filing</th></tr></thead>
            <tbody>
              {primaryApi.companies.map((company) => (
                <tr class={cohortIds.has(company.id) ? 'included' : ''}>
                  <th>{company.name}{company.product_aliases ? <small> ({company.product_aliases.join(', ')})</small> : ''}</th>
                  <td>{company.role}</td>
                  <td><span class="status">{cohortIds.has(company.id) ? 'IN COHORT' : statusLabel[company.quantitative_status]}</span></td>
                  <td class="number">{company.facts.length}</td>
                  <td>{company.facts.length ? `${company.facts[0].period_start} → ${company.facts[0].period_end}` : 'NO REPORTED FACT'}</td>
                  <td>{company.recent_filings && company.recent_filings.length > 0 ? <a class="source-link" href={company.recent_filings[0].source_url} target="_blank" rel="noreferrer">{company.recent_filings[0].form} / {company.recent_filings[0].filed} ↗</a> : 'NO PUBLIC FILING'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section id="audit" class="section audit">
        <div class="section-head"><div><p class="eyebrow">05 / AUDIT</p><h2>未解決の境界</h2></div><span class="section-note">{findings.length ? `${findings.length} OPEN` : 'NO OPEN FINDINGS'}</span></div>
        {findings.length ? <div class="finding-list">{findings.map((finding) => <article><span>{finding.severity.toUpperCase()}</span><div><strong>{finding.id.replaceAll('_', ' ')}</strong><p>{finding.detail}</p></div></article>)}</div> : <p class="clean">入力契約と一次資料の必須項目を確認済み。</p>}
        <div class="provenance"><span>SNAPSHOT AS OF</span><b>{stamp(snapshot.as_of)}</b><span>PRIMARY API HASH</span><b>{snapshot.primary_api_content_hash}</b><span>SNAPSHOT HASH</span><b>{model.snapshot_hash}</b><span>SELECTION RULE</span><b>{snapshot.selection_rule}</b></div>
      </section>

      <footer><span>PRIMARY FACTS / evidence before interpretation</span><span>Source: SEC EDGAR · no investment advice</span></footer>
    </main>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { background: #0a0d0c; scroll-behavior: smooth; }
  :global(body) { margin: 0; color: #e9eee5; background: #0a0d0c; font-family: "Noto Sans JP", "Yu Gothic", sans-serif; }
  :global(a) { color: inherit; }
  .shell { width: min(1280px, calc(100% - 42px)); margin: auto; padding: 22px 0 55px; }
  .topbar { display: flex; justify-content: space-between; align-items: center; min-height: 52px; border-bottom: 1px solid #29332d; }
  .brand, nav a, .eyebrow, .metric-grid span, .hero-meta span, .section-note, .section-head + .intro, .label, .equation span, .card-foot span, footer { font-family: "IBM Plex Mono", monospace; letter-spacing: .08em; text-transform: uppercase; }
  .brand { display: flex; gap: 9px; align-items: center; color: #f2f5eb; font: .72rem "IBM Plex Mono", monospace; text-decoration: none; }
  .brand-mark { display: grid; place-items: center; width: 22px; height: 22px; border: 1px solid #b8ee67; color: #b8ee67; }
  nav { display: flex; gap: 22px; } nav a { color: #87958a; font-size: .6rem; text-decoration: none; } nav a:hover, .text-link:hover, .source-link:hover { color: #c7f477; }
  .hero { display: grid; grid-template-columns: minmax(0, 1fr) 330px; gap: 55px; padding: clamp(65px, 10vw, 130px) 0 70px; border-bottom: 1px solid #29332d; }
  .eyebrow { display: flex; align-items: center; gap: 10px; margin: 0 0 20px; color: #8d9b90; font-size: .62rem; }
  .live-dot { width: 8px; height: 8px; border-radius: 50%; background: #c7f477; box-shadow: 0 0 15px #c7f477; }
  h1, h2, h3 { margin: 0; font-family: "Noto Serif JP", serif; font-weight: 500; letter-spacing: -.05em; } h1 { max-width: 790px; color: #f0f4e9; font-size: clamp(3.2rem, 8vw, 7.8rem); line-height: .96; } h1 em { color: #c7f477; font-style: normal; }
  .lede { max-width: 680px; margin: 28px 0 0; color: #8e9b91; font-size: .98rem; line-height: 1.9; }
  .hero-meta { display: grid; align-content: center; gap: 18px; padding-left: 24px; border-left: 1px solid #3c4b3d; } .hero-meta div { display: grid; gap: 6px; } .hero-meta span, .metric-grid span { color: #69776d; font-size: .55rem; } .hero-meta b { color: #e5ecdf; font: .72rem "IBM Plex Mono", monospace; } .hero-meta .state { color: #c7f477; }
  .truth-banner { display: grid; grid-template-columns: 63px 1fr; gap: 18px; align-items: center; margin: 28px 0 0; padding: 18px; border: 1px solid #566a42; background: linear-gradient(110deg, rgb(199 244 119 / .11), transparent 65%); } .seal { display: grid; place-items: center; width: 50px; height: 50px; border: 1px solid #c7f477; color: #c7f477; font: .5rem "IBM Plex Mono", monospace; line-height: 1.2; text-align: center; } .truth-banner strong { color: #eaf4df; font: 1.12rem "Noto Serif JP", serif; } .truth-banner p { margin: 6px 0 0; color: #94a198; font-size: .78rem; line-height: 1.7; }
  .metric-grid { display: grid; grid-template-columns: repeat(4, 1fr); margin: 28px 0 90px; border-top: 1px solid #29332d; border-bottom: 1px solid #29332d; } .metric-grid article { min-height: 142px; padding: 20px 18px 18px 0; border-right: 1px solid #29332d; } .metric-grid article:not(:first-child) { padding-left: 18px; } .metric-grid article:last-child { border-right: 0; } .metric-grid strong { display: block; margin: 20px 0 6px; color: #c7f477; font: 500 clamp(1.6rem, 3vw, 2.4rem) "IBM Plex Mono", monospace; } .metric-grid small { color: #718077; font-size: .68rem; }
  .section { margin: 0 0 88px; } .section-head { display: flex; justify-content: space-between; align-items: end; gap: 20px; margin-bottom: 20px; } h2 { color: #eff3e9; font-size: clamp(2rem, 4vw, 4rem); line-height: 1; } .text-link, .source-link { color: #c7f477; font: .6rem "IBM Plex Mono", monospace; text-decoration: none; } .section-note { color: #6f7d73; font-size: .56rem; } .intro { max-width: 780px; margin: 0 0 20px; color: #8d9a90; font-size: .82rem; line-height: 1.8; }
  .table-wrap { overflow-x: auto; border: 1px solid #29332d; background: #0f1511; } table { width: 100%; min-width: 980px; border-collapse: collapse; font-size: .72rem; } caption { padding: 15px; color: #67756b; font: .57rem "IBM Plex Mono", monospace; text-align: left; text-transform: uppercase; letter-spacing: .08em; } th, td { padding: 13px 15px; border-top: 1px solid #29332d; text-align: left; vertical-align: top; } thead th { color: #69776d; font: .56rem "IBM Plex Mono", monospace; letter-spacing: .07em; text-transform: uppercase; white-space: nowrap; } tbody th { color: #edf2e8; font: 600 .84rem "Noto Serif JP", serif; } tbody th small { display: block; margin-top: 4px; color: #68766d; font: .57rem "IBM Plex Mono", monospace; } td { color: #9aa79c; } .number { color: #dff0d4; font: .75rem "IBM Plex Mono", monospace; white-space: nowrap; } code { display: block; margin: 3px 0; color: #dda76d; font: .56rem "IBM Plex Mono", monospace; white-space: nowrap; }
  .ledger-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; } .ledger-card { padding: 21px; border: 1px solid #29332d; background: #0f1511; } .ledger-card header { display: grid; grid-template-columns: 28px 1fr auto; gap: 11px; align-items: start; } .index { color: #65736a; font: .65rem "IBM Plex Mono", monospace; } .ledger-card h3 { color: #edf2e8; font-size: 1.25rem; } .ledger-card header small { color: #6f7d73; font: .57rem "IBM Plex Mono", monospace; } .equation { display: grid; grid-template-columns: 1fr auto 1fr; gap: 12px; align-items: center; margin: 25px 0 13px; padding: 15px 0; border-top: 1px solid #29332d; border-bottom: 1px solid #29332d; } .equation span, .card-foot span { display: block; color: #6b796f; font-size: .53rem; } .equation strong { display: block; margin: 9px 0 6px; color: #c7f477; font: .86rem "IBM Plex Mono", monospace; white-space: nowrap; } .equation > b { color: #64736a; font: 1.2rem "IBM Plex Mono", monospace; } .card-foot { display: flex; justify-content: space-between; gap: 12px; align-items: baseline; } .card-foot strong { color: #e6eee0; font: .85rem "IBM Plex Mono", monospace; }
  .derived { padding: 25px 0 0; border-top: 1px solid #29332d; } .derived-grid { display: grid; grid-template-columns: 1fr 1fr 1.6fr; gap: 10px; } .derived-grid article { min-height: 145px; padding: 18px; border: 1px solid #3c4b3d; background: #111a13; } .label { color: #75847a; font-size: .55rem; } .derived-grid strong { display: block; margin: 18px 0 8px; color: #e8f2e2; font: 1.45rem "IBM Plex Mono", monospace; } .derived-grid p { margin: 0; color: #88968c; font-size: .74rem; line-height: 1.7; } .tag-group { display: flex !important; justify-content: space-between; gap: 15px; padding: 7px 0; border-bottom: 1px solid #29332d; } .tag-group b { color: #c7f477; font: .7rem "IBM Plex Mono", monospace; white-space: nowrap; }
  .coverage .included { background: rgb(199 244 119 / .05); } .status { color: #dda76d; font: .57rem "IBM Plex Mono", monospace; white-space: nowrap; } .included .status { color: #c7f477; }
  .audit { padding-top: 25px; border-top: 1px solid #29332d; } .finding-list { display: grid; gap: 8px; } .finding-list article { display: grid; grid-template-columns: 85px 1fr; gap: 15px; padding: 15px 0; border-bottom: 1px solid #29332d; } .finding-list article > span { color: #dda76d; font: .57rem "IBM Plex Mono", monospace; } .finding-list strong { color: #edf2e8; font: .78rem "IBM Plex Mono", monospace; } .finding-list p { margin: 5px 0 0; color: #89968d; font-size: .76rem; } .clean { color: #c7f477; font: .72rem "IBM Plex Mono", monospace; } .provenance { display: grid; grid-template-columns: 160px 1fr; gap: 10px 18px; margin-top: 28px; padding: 17px; border: 1px solid #29332d; background: #0f1511; } .provenance span { color: #69776d; font: .55rem "IBM Plex Mono", monospace; } .provenance b { color: #b0bdb1; font: .62rem "IBM Plex Mono", monospace; line-height: 1.5; overflow-wrap: anywhere; }
  footer { display: flex; justify-content: space-between; gap: 20px; padding-top: 18px; border-top: 1px solid #29332d; color: #5f6d64; font-size: .55rem; }
  @media (max-width: 850px) { .hero { grid-template-columns: 1fr; gap: 35px; } .hero-meta { grid-template-columns: 1fr 1fr; padding: 20px 0 0; border-left: 0; border-top: 1px solid #3c4b3d; } .metric-grid { grid-template-columns: repeat(2, 1fr); } .metric-grid article:nth-child(2) { border-right: 0; } .metric-grid article:nth-child(n + 3) { border-top: 1px solid #29332d; } .ledger-grid, .derived-grid { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .shell { width: min(100% - 26px, 1280px); } nav { gap: 10px; } nav a { font-size: .51rem; } .hero { padding-top: 60px; } h1 { font-size: clamp(3rem, 17vw, 5rem); } .hero-meta { grid-template-columns: 1fr; } .metric-grid strong { font-size: 1.35rem; } .section-head { align-items: start; flex-direction: column; } .equation { grid-template-columns: 1fr; } .equation > b { display: none; } .provenance { grid-template-columns: 1fr; gap: 5px; } footer { flex-direction: column; } }
</style>
