---
import fs from 'node:fs';
import path from 'node:path';
import { buildDemandAggregation } from '../lib/demand-aggregation.js';

const root = process.cwd().endsWith('site') ? path.resolve(process.cwd(), '..') : process.cwd();
const model = JSON.parse(fs.readFileSync(path.join(root, 'site/public/data/quant-audit.json'), 'utf8'));
const primaryApi = JSON.parse(fs.readFileSync(path.join(root, 'site/public/api/v1/index.json'), 'utf8'));
const profitApi = JSON.parse(fs.readFileSync(path.join(root, 'site/public/api/v1/semiconductor-profit/index.json'), 'utf8'));
const demandApi = JSON.parse(fs.readFileSync(path.join(root, 'site/public/api/v1/demand/index.json'), 'utf8'));
const snapshot = model.snapshot;
const normalized = model.normalized;
const sources = snapshot.sources;
const findings = model.audit.findings;
const base = import.meta.env.BASE_URL;
const buildSha = import.meta.env.PUBLIC_BUILD_SHA;
if (!buildSha) throw new Error('PUBLIC_BUILD_SHA is required for provenance');

const usd = (value) => `$${(Number(value) / 1_000_000_000).toFixed(3)}B`;
const exactUsd = (value) => `$${Number(value).toLocaleString('en-US')} USD`;
const dateJP = (value) => {
  const [year, month, day] = value.slice(0, 10).split('-').map(Number);
  return `${year}年${month}月${day}日`;
};
const periodLabel = `${dateJP(snapshot.primary_period.start)}〜${dateJP(snapshot.primary_period.end)}`;
const cohortIds = new Set(sources.map((source) => source.id));
const profitCompanies = profitApi.companies.filter((company) => company.quarters.length > 0);
const profitHistoryQuarters = profitCompanies.length ? Math.min(...profitCompanies.map((company) => company.quarters.length)) : 0;
const demandCompanies = demandApi.companies.filter((company) => company.quarters.length > 0);
const demandHistoryQuarters = demandCompanies.length ? Math.min(...demandCompanies.map((company) => company.quarters.length)) : 0;
const demandAggregation = buildDemandAggregation(demandApi);
const { commonDemandPeriod, commonDemandCompanies } = {
  commonDemandPeriod: demandAggregation.commonPeriod,
  commonDemandCompanies: demandAggregation.commonCompanies,
};
const currentStatus = demandAggregation.ready ? '総括済み' : '集計待ち';
const currentStatusDescription = demandAggregation.ready
  ? '同一期間・タグ別の総和と比較を計算済み'
  : '同一期間の集計対象が不足';
const latestProfit = (company) => company.quarters[0];
const latestDemand = (company) => company.quarters[0];
const operatingMargin = (company) => {
  const quarter = latestProfit(company);
  const revenue = Number(quarter?.revenue?.reported_value);
  const income = Number(quarter?.operating_income?.reported_value);
  return revenue ? income / revenue * 100 : null;
};
const previousYearQuarter = (company) => {
  const current = latestProfit(company);
  if (current?.fiscal_year == null || current?.fiscal_period == null) return null;
  return company.quarters.find((quarter) => quarter.fiscal_year === current.fiscal_year - 1 && quarter.fiscal_period === current.fiscal_period) || null;
};
const yoyIncome = (company) => {
  const current = latestProfit(company)?.operating_income.reported_value;
  const previous = previousYearQuarter(company)?.operating_income.reported_value;
  if (current == null || previous == null || previous === 0) return null;
  return (Number(current) / Number(previous) - 1) * 100;
};
const chartHeight = (company, value) => {
  const max = Math.max(...company.quarters.map((quarter) => Math.abs(Number(quarter.operating_income.reported_value))), 1);
  return Math.max(3, Math.round(Math.abs(Number(value)) / max * 100));
};
const pct = (value) => `${value >= 0 ? '+' : ''}${value.toFixed(1)}%`;
const marginPct = (value) => value == null ? '計算不可' : `${value.toFixed(1)}%`;
const ratio = (value) => value == null ? '計算不可' : `${(Number(value) * 100).toFixed(1)}%`;
const capexTagCount = normalized.capital_expenditures_fact_tag_count;
const capexIsComparable = capexTagCount === 1;
const capexSummary = capexIsComparable
  ? '設備投資は同じタグで揃っているため、合計を表示します。'
  : `設備投資は${capexTagCount}種類のタグに分かれるため、全社合計は計算しません。`;
const findingSummary = {
  capital_expenditure_concepts_not_comparable: `設備投資が${capexTagCount}種類のXBRLタグに分かれるため、全社の設備投資合計と残差は公開していません。`,
};

const statusCopy = {
  reported_facts_same_period: { label: '数字あり', description: '同じ四半期のOCFと設備投資を確認' },
  public_no_10q_facts_yet: { label: '10-Q待ち', description: '公開企業だが、まだ10-Qのfactなし' },
  public_no_quarterly_10q_facts: { label: '四半期数字なし', description: '公開資料に対象factなし' },
  capital_expenditure_fact_unavailable: { label: '設備投資なし', description: '設備投資factが未取得' },
  operating_cash_flow_fact_unavailable: { label: '営業CFなし', description: '営業CF factが未取得' },
  reported_facts_period_mismatch: { label: '期間不一致', description: '2つの数字が同じ四半期ではない' },
  excluded_without_estimate: { label: '公開数字なし', description: '非公開企業のため推定しない' },
};
for (const company of primaryApi.companies) {
  if (!(company.quantitative_status in statusCopy)) throw new Error(`Unknown quantitative status: ${company.quantitative_status}`);
}
const sourceFor = (source) => source.operating_cash_flow_source_url;
const companyApiFor = (source) => `${base}api/v1/companies/${source.id}.json`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="顧客の資金余力が半導体企業の利益成長を支えられるかを、SEC一次factで検証する。" />
    <title>半導体利益の持続可能性 / 一次情報台帳</title>
  </head>
  <body>
    <main class="page">
      <header class="topbar">
        <a class="brand" href={base} aria-label="トップへ戻る"><span class="brand-mark">＋</span><span>決算の読み方<span class="brand-sub"> / PRIMARY FACTS</span></span></a>
        <nav aria-label="ページ内ナビゲーション">
          <a href="#how">読み方</a>
          <a href="#demand">需要推移</a>
          <a href="#profit">利益推移</a>
          <a href="#companies">会社別</a>
          <a href="#limits">注意点</a>
          <a href={`${base}model/`}>計算モデル ↗</a>
        </nav>
      </header>

      <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="kicker"><span class="status-dot"></span>EVIDENCE-BOUND / 30秒で現在地</p>
          <h1 id="page-title"><span>高い半導体利益成長は、</span><em>顧客の資金余力で支えられるか。</em></h1>
          <p class="hero-lede">SEC一次factから、営業CF・設備投資・半導体企業の売上と営業利益を最大5年追います。需要の強さではなく、投資を継続できる資金力と利益率の維持を検証します。</p>
          <div class="hero-actions">
            <a class="button button-primary" href="#how">まず読み方を見る <span>↓</span></a>
            <a class="button button-quiet" href="#status">現在の判定 <span>→</span></a>
          </div>
        </div>
        <aside class="hero-card" aria-label="今回のデータ範囲">
          <p class="card-kicker">現在の判定</p>
          <strong class="verdict" data-aggregation-status={demandAggregation.ready ? 'computed' : 'insufficient'}>{currentStatus}</strong>
          <p>{currentStatusDescription}</p>
          <div class="hero-card-rule"></div>
          <span>総和と比較は計算済み。顧客投資から半導体利益への因果・将来推計はまだ判定しません。</span>
        </aside>
      </section>

      <section id="how" class="how section-block" aria-labelledby="how-title">
        <div class="section-intro">
          <p class="section-number">01 / LOGIC</p>
          <h2 id="how-title">判定までの、<br /><em>論理。</em></h2>
        </div>
        <div class="how-grid">
          <article class="how-card"><span class="step">01</span><div><h3>資金を生む</h3><p>顧客企業の営業CFが伸びているかを確認します。</p></div></article>
          <article class="how-card"><span class="step">02</span><div><h3>投資を続ける</h3><p>CapEx、FCF、外部資金で投資余力を確認します。</p></div></article>
          <article class="how-card"><span class="step">03</span><div><h3>利益へ転換する</h3><p>半導体企業の売上、営業利益、利益率を確認します。</p></div></article>
          <article class="how-card"><span class="step">04</span><div><h3>指数へ接続する</h3><p>公式ウェイトと期間が揃って初めて指数利益を判定します。</p></div></article>
        </div>
      </section>

      <section id="status" class="snapshot section-block" aria-labelledby="snapshot-title">
        <div class="section-heading">
          <div><p class="section-number">02 / CURRENT STATE</p><h2 id="snapshot-title">現在の判定。</h2></div>
          <span class="period-chip">{periodLabel}</span>
        </div>
        <div class="verdict-panel">
          <div><span>判定</span><strong>{currentStatus}</strong></div>
          <p>顧客側の営業CF・設備投資は同一期間・同一XBRLタグごとに総和と比較を計算済みです。半導体企業の売上・営業利益も会社別に確認できます。ただし、顧客投資から半導体利益への因果、外部資金の複数年継続能力、公式ウェイトによる指数利益は未検証です。</p>
        </div>
        <div class="evidence-grid">
          <article class="evidence-card evidence-observed"><span>OBSERVED / 顧客側</span><strong>{commonDemandCompanies.length}<small>社</small> / {commonDemandPeriod ? dateJP(commonDemandPeriod) : '期間未確定'}</strong><p>同一最新期間の営業CF・設備投資</p></article>
          <article class="evidence-card evidence-observed"><span>OBSERVED / 半導体側</span><strong>{profitCompanies.length}<small>社</small> / {profitHistoryQuarters}<small>四半期以上</small></strong><p>売上高・営業利益の時系列</p></article>
          <article class="evidence-card evidence-derived"><span>DERIVED / 総括済み</span><strong>OCF {usd(demandAggregation.totalOcf)}</strong><p>{demandAggregation.tagTotals.length}種類のCapExタグ別に積み上げ</p></article>
          <article class="evidence-card evidence-unknown"><span>UNKNOWN / 因果・予測</span><strong>売上転換・指数</strong><p>配分率、ラグ、利益率、公式ウェイトは未判定</p></article>
        </div>
        <div class="boundary-note"><span class="note-icon">i</span><p><strong>総括計算は完了しています。</strong> 顧客{commonDemandCompanies.length}社の同一期間factをタグ別に積み上げ、コホート比較しました。これは足し算の成立であり、半導体利益への因果成立ではありません。</p></div>
      </section>

      <section id="demand" class="demand section-block" aria-labelledby="demand-title">
        <div class="section-heading">
          <div><p class="section-number">03 / FUNDING CAPACITY</p><h2 id="demand-title">内部資金と<br /><em>投資負担。</em></h2></div>
          <a class="outline-link" href={`${base}api/v1/demand/index.json`}>需要APIを開く <span>↗</span></a>
        </div>
        <p class="section-lede">営業CFが投資を何年支えられるかを、同じ四半期の営業CF・設備投資で追います。正規化バーは同一社内の時間変化だけを比較し、実額と元factはAPIで確認できます。</p>
        <div class="demand-chain" aria-label="資金余力から半導体利益までの検証順"><span class="chain-node observed">営業CF</span><b>→</b><span class="chain-node observed">CapEx</span><b>→</b><span class="chain-node unknown">リース・借入 <small>未取得</small></span><b>→</b><span class="chain-node hypothesis">半導体売上</span><b>→</b><span class="chain-node hypothesis">営業利益</span></div>
        <div class="profit-bridge">
          <div><span>内部資金を読める企業</span><strong>{demandCompanies.length}<small>社</small></strong><p>営業CF＋設備投資</p></div>
          <div><span>履歴</span><strong>{demandHistoryQuarters}<small>四半期以上</small></strong><p>最大20四半期を保存</p></div>
          <div><span>正規化</span><strong>100<small>基準</small></strong><p>各社の最大絶対値</p></div>
        </div>
        <div class="time-view-head"><div><span class="section-number">TIME VIEW / OBSERVED CASH FLOW</span><h3>営業CFと設備投資のバーを見る</h3></div><span class="chart-legend"><i></i>営業CF　<i class="legend-capex"></i>設備投資</span></div>
        <p class="chart-note">チャートの高さは同じ会社の中だけで比較できます。各社間の規模比較には、下の実額を使います。</p>
        <div class="profit-chart-grid">
          {demandCompanies.map((company) => (
            <article class="profit-chart-card demand-chart-card">
              <header><div><h3>{company.name}</h3><p>{company.ticker} · {company.role}</p></div><strong><span class="metric-label">最新設備投資</span>{usd(latestDemand(company).capital_expenditures.value_usd)}</strong></header>
              <p class="profit-yoy">設備投資 / 営業CF {ratio(latestDemand(company).capital_expenditure_to_operating_cash_flow)}　<span class="derived-note">同一四半期</span></p>
              <div class="bar-chart demand-bar-chart" role="img" aria-label={`${company.name}の営業CFと設備投資、過去${company.quarters.length}四半期`}>
                <div class="bar-zero"></div>
                {company.quarters.slice().reverse().map((quarter, index) => {
                  const ocf = Number(quarter.operating_cash_flow.normalized_value);
                  const capex = Number(quarter.capital_expenditures.normalized_value);
                  return <div class="bar-column demand-bar-column"><div class="demand-bar-pair"><div class:list={['bar-value', 'demand-ocf', ocf < 0 ? 'negative' : 'positive']} style={`--bar-size:${Math.max(3, Math.abs(ocf))}%`} title={`${quarter.period_end} 営業CF ${exactUsd(quarter.operating_cash_flow.value_usd)}`}></div><div class:list={['bar-value', 'demand-capex', capex < 0 ? 'negative' : 'positive']} style={`--bar-size:${Math.max(3, Math.abs(capex))}%`} title={`${quarter.period_end} 設備投資 ${exactUsd(quarter.capital_expenditures.value_usd)}`}></div></div><small>{index % 4 === 0 || index === company.quarters.length - 1 ? quarter.period_end.slice(0, 7) : ''}</small></div>;
                })}
              </div>
              <div class="profit-chart-foot"><span>営業CF {usd(latestDemand(company).operating_cash_flow.value_usd)} / 設備投資 {usd(latestDemand(company).capital_expenditures.value_usd)}</span><a href={`${base}api/v1/demand/companies/${company.id}.json`}>fact API ↗</a></div>
            </article>
          ))}
        </div>
      </section>

      <section id="profit" class="profit section-block" aria-labelledby="profit-title">
        <div class="section-heading">
          <div><p class="section-number">04 / PROFIT CONVERSION</p><h2 id="profit-title">売上は、<br /><em>利益に変わったか。</em></h2></div>
          <a class="outline-link" href={profitApi.target.index_url} target="_blank" rel="noreferrer">SOXの定義を見る <span>↗</span></a>
        </div>
        <p class="section-lede">売上高と営業利益を同じ四半期で読み、営業利益率の変化を確認します。バーは各社の最大値を100に正規化した形の比較です。会計期末が違うため、指数利益は再構成しません。</p>
        <div class="profit-bridge">
          <div><span>直接読める企業</span><strong>{profitCompanies.length}<small>社</small></strong><p>売上高＋営業利益</p></div>
          <div><span>履歴</span><strong>{profitHistoryQuarters}<small>四半期以上</small></strong><p>最大20四半期を保存</p></div>
          <div><span>共通期間</span><strong>{profitApi.cohort.status === 'unique' ? '成立' : '期間未確定'}</strong><p>{profitApi.cohort.status === 'unique' ? '同じ期間だけ集計可能' : '異なる期間を合算しない'}</p></div>
        </div>
        <div class="time-view-head"><div><span class="section-number">TIME VIEW / OBSERVED PROFIT</span><h3>四半期ごとのバーを見る</h3></div><span class="chart-legend"><i></i>営業利益　<i class="legend-negative"></i>赤字</span></div>
        <div class="profit-chart-grid">
          {profitCompanies.map((company) => (
            <article class="profit-chart-card">
              <header><div><h3>{company.name}</h3><p>{company.ticker} · {company.role}</p></div><strong><span class="metric-label">最新営業利益</span>{usd(latestProfit(company).operating_income.reported_value)}</strong></header>
              <p class="profit-yoy">前年同期比 {yoyIncome(company) === null ? '計算不可' : pct(yoyIncome(company))}　/　営業利益率 {marginPct(operatingMargin(company))}</p>
              <div class="bar-chart" role="img" aria-label={`${company.name}の営業利益、過去${company.quarters.length}四半期`}>
                <div class="bar-zero"></div>
                {company.quarters.slice().reverse().map((quarter, index) => {
                  const value = Number(quarter.operating_income.reported_value);
                  return <div class="bar-column"><div class:list={['bar-value', value < 0 ? 'negative' : 'positive']} style={`--bar-size:${chartHeight(company, value)}%`} title={`${quarter.period_end} 営業利益 ${exactUsd(value)}`}></div><small>{index % 4 === 0 || index === company.quarters.length - 1 ? quarter.period_end.slice(0, 7) : ''}</small></div>;
                })}
              </div>
              <div class="profit-chart-foot"><span>売上高 {usd(latestProfit(company).revenue.reported_value)} / 利益率 {marginPct(operatingMargin(company))}</span><a href={`${base}api/v1/semiconductor-profit/companies/${company.id}.json`}>fact API ↗</a></div>
            </article>
          ))}
        </div>
      </section>

      <section id="companies" class="companies section-block" aria-labelledby="companies-title">
        <div class="section-heading">
          <div><p class="section-number">05 / SOURCE FACTS</p><h2 id="companies-title">会社別の原fact。</h2></div>
          <a class="outline-link" href={`${base}api/v1/index.json`}>データ一覧を開く <span>↗</span></a>
        </div>
        <p class="section-lede">カードは現在の同じ四半期の報告値です。時系列バーの正規化値と混ぜず、実額とXBRLタグを1社ずつ確認できます。</p>
        <div class="company-grid">
          {sources.map((source, index) => (
            <article class="company-card">
              <header class="company-head">
                <span class="company-index">{String(index + 1).padStart(2, '0')}</span>
                <div><h3>{source.label}</h3><p>{source.ticker} · {dateJP(source.period_end)}時点</p></div>
                <span class="verified-badge">SEC factあり</span>
              </header>
              <div class="company-values">
                <div><span>営業CF</span><strong>{usd(source.operating_cash_flow_usd)}</strong><small>入ったお金</small></div>
                <div><span>設備投資</span><strong>{usd(source.capital_expenditures_usd)}</strong><small>使ったお金</small></div>
              </div>
              <div class="company-foot"><a href={sourceFor(source)} target="_blank" rel="noreferrer">SEC提出書類を見る <span>↗</span></a><a href={companyApiFor(source)}>この会社のAPI <span>→</span></a></div>
              <details class="raw-details"><summary>タグと正確な値を表示</summary><dl><dt>営業CF tag</dt><dd>{source.operating_cash_flow_fact_tag}</dd><dt>設備投資 tag</dt><dd>{source.capital_expenditures_fact_tag}</dd><dt>営業CF raw</dt><dd>{exactUsd(source.operating_cash_flow_usd)}</dd><dt>設備投資 raw</dt><dd>{exactUsd(source.capital_expenditures_usd)}</dd></dl></details>
            </article>
          ))}
        </div>
      </section>

      <section id="limits" class="limits section-block" aria-labelledby="limits-title">
        <div class="section-heading"><div><p class="section-number">06 / DECISION BOUNDARY</p><h2 id="limits-title">どこまで、<em>判定できるか。</em></h2></div></div>
        <div class="meaning-grid">
          <article class="meaning-card meaning-card-good"><span class="meaning-mark">◎</span><h3>観測できること</h3><ul><li>顧客企業の営業CF・CapExを時系列で追う</li><li>半導体企業の売上・営業利益・利益率を見る</li><li>同一社内の5年変化と元factを確認する</li></ul></article>
          <article class="meaning-card meaning-card-limit"><span class="meaning-mark">!</span><h3>まだ判定できないこと</h3><ul><li>リース・借入で何年投資を補えるか</li><li>顧客投資が半導体利益を生んだ因果関係</li><li>公式ウェイトによる指数利益成長</li></ul></article>
          <article class="meaning-card meaning-card-watch"><span class="meaning-mark">△</span><h3>仮説を棄却する条件</h3><ul><li>営業CF成長の一桁化</li><li>CapEx / 営業CFの上昇継続</li><li>半導体企業の利益率低下</li></ul></article>
        </div>
        {findings.length ? <div class="audit-callout"><span class="warning-icon">!</span><div><strong>今回の注意点</strong><p>{findingSummary[findings[0].id] || findings[0].detail}</p></div><a href="#technical">技術情報 <span>↓</span></a></div> : null}
      </section>

      <section class="coverage section-block" aria-labelledby="coverage-title">
        <details class="coverage-details">
          <summary><span><span class="section-number">07 / COVERAGE</span><strong id="coverage-title">対象企業をすべて見る</strong></span><span class="summary-count">{primaryApi.companies.length}社の登録状況 <b>＋</b></span></summary>
          <p class="section-lede">登録されている企業のうち、同じ期間の一次factが揃った会社だけが上のカードに入ります。欠測はゼロや推定値に変換しません。</p>
