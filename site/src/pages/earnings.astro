---
import fs from 'node:fs';
import path from 'node:path';

const root = process.cwd().endsWith('site') ? path.resolve(process.cwd(), '..') : process.cwd();
const dataPath = path.join(root, 'site/public/data/quant-audit.json');
if (!fs.existsSync(dataPath)) throw new Error(`Missing generated model data: ${dataPath}`);
const model = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
const snapshot = model.snapshot;
const consensus = snapshot.consensus;
const base = import.meta.env.BASE_URL;

const pct = (value, digits = 1) => `${Number(value) >= 0 ? '+' : ''}${Number(value).toFixed(digits)}%`;
const pct0 = (value) => `${Number(value) >= 0 ? '+' : ''}${(Number(value) * 100).toFixed(1)}%`;
const bn = (value) => `$${Number(value).toFixed(1)}B`;
const range = (values) => `${pct(values[0])} → ${pct(values[1])}`;
const titleCase = (value) => value.charAt(0).toUpperCase() + value.slice(1);
const severityLabel = { critical: 'CRITICAL', major: 'MAJOR', minor: 'MINOR' };
const verdictLabel = { conditional: 'CONDITIONAL', supported: 'SUPPORTED', blocked: 'BLOCKED' };
const verdictJa = { conditional: '条件付き妥当', supported: '支持', blocked: '保留' };
const consensusMargin = consensus.forward_margin * (1 + consensus.operating_earnings_growth_2027) / (1 + consensus.revenue_growth_2027);
const modelRows = model.scenarios.map((scenario) => ({
  ...scenario,
  label: titleCase(scenario.name),
  earnings: range(scenario.operating_earnings_growth_range),
  revenue: range(scenario.revenue_growth_range),
  barLeft: Math.max(0, Math.min(100, (scenario.revenue_growth_range[0] + 30) * 0.8)),
  barWidth: Math.max(4, Math.min(100, (scenario.revenue_growth_range[1] - scenario.revenue_growth_range[0]) * 0.8)),
}));
const baseScenario = modelRows.find((scenario) => scenario.name === 'base') || modelRows[0];
const sources = snapshot.sources;
const openFindings = model.audit.findings.filter((finding) => finding.status === 'open');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="一次資料のスナップショットから再計算する、半導体市場の決算モデル。" />
    <title>決算モデル / Signal Room</title>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <main class="shell">
      <header class="topbar">
        <a class="brand" href={base}><span class="brand-dot"></span>KAFKA / MODEL ROOM</a>
        <nav aria-label="ページ内ナビゲーション">
          <a href="#scenarios">シナリオ</a>
          <a href="#evidence">証拠</a>
          <a href="#method">モデル定義</a>
        </nav>
      </header>

      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow"><span class="pulse"></span> EARNINGS MODEL / VERSIONED SNAPSHOT</p>
          <h1>数字が変わるたび、<em>前提</em>から更新する。</h1>
          <p class="dek">ハイパースケーラーのキャッシュ創出、半導体コンセンサス、利益率を同じ入力スナップショットから再計算する。予言ではなく、更新できる監査面。</p>
        </div>
        <aside class="hero-stamp">
          <div class="stamp-ring"><span>Q</span><strong>01</strong></div>
          <div><span class="micro">GRAPH VERSION</span><b>{snapshot.graph_version}</b></div>
          <div><span class="micro">SNAPSHOT</span><b>{snapshot.as_of}</b></div>
          <div><span class="micro">STATE</span><b class="state">{verdictLabel[model.audit.verdict] || model.audit.verdict}</b></div>
        </aside>
      </section>

      <section class="kpi-grid" aria-label="主要指標">
        <article class="kpi kpi-accent"><span>2027 consensus / revenue</span><strong>{pct0(consensus.revenue_growth_2027)}</strong><small>Yardeni · {consensus.as_of}</small></article>
        <article class="kpi"><span>2027 consensus / operating earnings</span><strong>{pct0(consensus.operating_earnings_growth_2027)}</strong><small>margin implies {pct0(consensusMargin)}</small></article>
        <article class="kpi"><span>base case / earnings range</span><strong>{range(baseScenario.operating_earnings_growth_range).replace(' → ', '—')}</strong><small>β = {snapshot.beta_range[0]}—{snapshot.beta_range[1]}</small></article>
        <article class="kpi"><span>capex proxy / operating CF</span><strong>{(model.normalized.capex_to_operating_cash_flow * 100).toFixed(1)}%</strong><small>{bn(model.normalized.capex_proxy_total)} / {bn(model.normalized.operating_cash_flow_total)}</small></article>
      </section>

      <section class="signal-strip" aria-label="判定">
        <div class="signal-led"><span class="signal-mark">!</span><div><span class="micro">MODEL VERDICT</span><strong>{verdictJa[model.audit.verdict] || model.audit.verdict}</strong></div></div>
        <p>{pct0(consensus.operating_earnings_growth_2027)}は強気レンジに入る。ただし、βは未推定、投資のラグは未実装、4社の設備投資定義は不統一。</p>
        <span class="confidence">confidence {Math.round(model.audit.confidence * 100)}%</span>
      </section>

      <section id="scenarios" class="section-block">
        <div class="section-heading"><div><p class="eyebrow">01 / SCENARIO MAP</p><h2>利益成長の地形</h2></div><div class="filterbar"><button class="filter active" data-filter="all">ALL CASES</button>{modelRows.map((row) => <button class="filter" data-filter={row.name}>{row.label.toUpperCase()}</button>)}</div></div>
        <div class="scenario-frame">
          <div class="axis"><span>−30%</span><span>0</span><span>+30%</span><span>+60%</span></div>
          {modelRows.map((row) => (
            <article class={`scenario-row ${row.name}`} data-scenario={row.name}>
              <div class="scenario-name"><span class="scenario-pin"></span><b>{row.label}</b><small>investment {pct(row.effective_investment_growth)}</small></div>
              <div class="range-track" aria-label={`${row.label} revenue range`}><span class="range-bar" style={`left:${row.barLeft}%;width:${row.barWidth}%`}></span><i class="zero-line"></i></div>
              <div class="scenario-values"><strong>{row.earnings}</strong><small>earnings</small><span>{row.revenue} rev.</span></div>
            </article>
          ))}
        </div>
        <div class="target-note"><span>MARKET TARGET</span><b>{pct0(consensus.operating_earnings_growth_2027)} operating earnings</b><span>only overlaps the bull case</span></div>
      </section>

      <section id="evidence" class="section-block">
        <div class="section-heading"><div><p class="eyebrow">02 / EVIDENCE LEDGER</p><h2>資金はどこから来るか</h2></div><span class="section-meta">Q1 2026 / USD billions</span></div>
        <div class="evidence-grid">
          {sources.map((source) => (
            <article class="evidence-card">
              <div class="evidence-top"><span class="source-index">0{sources.indexOf(source) + 1}</span><h3>{source.label}</h3><a href={source.source_url} target="_blank" rel="noreferrer">10-Q ↗</a></div>
              <div class="evidence-numbers"><div><span>OPERATING CF</span><strong>{bn(source.operating_cash_flow)}</strong></div><div><span>CAPEX PROXY</span><strong>{bn(source.capex_proxy)}</strong></div></div>
              <p><span class="definition-dot"></span>{source.capex_definition.replaceAll('_', ' ')}</p>
            </article>
          ))}
        </div>
        <div class="evidence-total"><div><span class="micro">AGGREGATED PROXY</span><strong>{bn(model.normalized.operating_cash_flow_total)} OCF</strong></div><div class="math-sign">−</div><div><span class="micro">CAPEX / LEASE MIX</span><strong>{bn(model.normalized.capex_proxy_total)}</strong></div><div class="math-sign">=</div><div class="total-result"><span class="micro">RESIDUAL PROXY</span><strong>{bn(model.normalized.residual_cash_flow_proxy)} <small>({(model.normalized.residual_margin_proxy * 100).toFixed(1)}%)</small></strong></div></div>
        <p class="footnote">※ 4社のcapex proxyは会計定義が異なる。合計はGAAP指標ではなく、AIインフラ投資負担の比較用スナップショット。</p>
      </section>

      <section class="audit-grid">
        <div class="section-heading compact"><div><p class="eyebrow">03 / AUDIT GATE</p><h2>未解決の前提</h2></div><span class="section-meta">{openFindings.length} OPEN FINDINGS</span></div>
        <div class="finding-list">
          {openFindings.map((finding) => (
            <div class="finding"><span class={`severity ${finding.severity}`}>{severityLabel[finding.severity]}</span><div><b>{finding.id.replaceAll('_', ' ')}</b><p>{finding.detail}</p></div><span class="open-dot"></span></div>
          ))}
        </div>
      </section>

      <section id="method" class="method-grid">
        <div class="method-intro"><p class="eyebrow">04 / MODEL DEFINITION</p><h2>再計算できる形にする。</h2><p>LangGraphはノード遷移だけを担当し、数式は純粋関数として固定。新しい決算は既存データを上書きせず、新しいスナップショットとして取り込む。</p><a class="text-link" href={`${base}earnings/`}>snapshot hash: {model.snapshot_hash.slice(0, 12)}… ↗</a></div>
        <div class="formula-card"><span class="micro">CORE EQUATIONS</span><code>gI = (1 + gOCF) × (1 − mFCF + f) / {snapshot.model_base_ratio} − 1</code><code>gR = β × gI</code><code>gE = (1 + gR) × (M1 / {pct0(consensus.forward_margin)}) − 1</code><div class="protocol"><span>UPDATE PROTOCOL</span><b>new snapshot → validate → normalize → calculate → audit → publish</b></div></div>
      </section>

      <footer class="footer"><span>MODEL ROOM / built from versioned evidence</span><span>not investment advice · status remains conditional</span></footer>
    </main>
    <script>
      const buttons = document.querySelectorAll('[data-filter]');
      const rows = document.querySelectorAll('[data-scenario]');
      buttons.forEach((button) => button.addEventListener('click', () => {
        buttons.forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        const filter = button.dataset.filter;
        rows.forEach((row) => { row.hidden = filter !== 'all' && row.dataset.scenario !== filter; });
      }));
    </script>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; background: #0a0d0e; }
  :global(body) { margin: 0; color: #e6eadf; background: #0a0d0e; font-family: "Noto Sans JP", "Yu Gothic", sans-serif; }
  :global(a) { color: inherit; }
  .noise { position: fixed; inset: 0; z-index: 10; pointer-events: none; opacity: .04; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 160 160' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.55'/%3E%3C/svg%3E"); }
  .shell { width: min(1320px, calc(100% - 42px)); margin: 0 auto; padding: 22px 0 50px; }
  .topbar { display: flex; justify-content: space-between; align-items: center; gap: 20px; min-height: 50px; border-bottom: 1px solid #27312e; }
  .brand, nav a, .eyebrow, .micro, .kpi span, .evidence-numbers span, .axis, .section-meta, .footer, .footnote, .target-note, .protocol span { font-family: "IBM Plex Mono", "SFMono-Regular", monospace; letter-spacing: .08em; text-transform: uppercase; }
  .brand { display: flex; gap: 10px; align-items: center; font-size: .72rem; text-decoration: none; color: #f2f5e8; }
  .brand-dot, .pulse { width: 9px; height: 9px; border-radius: 50%; background: #c9f45a; box-shadow: 0 0 0 5px rgb(201 244 90 / .09), 0 0 20px rgb(201 244 90 / .55); }
  nav { display: flex; gap: 22px; }
  nav a { font-size: .64rem; color: #7d8a83; text-decoration: none; } nav a:hover { color: #c9f45a; }
  .hero { display: grid; grid-template-columns: minmax(0, 1fr) 255px; gap: 36px; padding: clamp(58px, 9vw, 122px) 0 70px; border-bottom: 1px solid #27312e; }
  .eyebrow { display: flex; align-items: center; gap: 12px; margin: 0 0 20px; color: #9aa79e; font-size: .68rem; }
  h1, h2 { margin: 0; font-family: "Noto Serif JP", "Hiragino Mincho ProN", serif; font-weight: 500; letter-spacing: -.055em; }
  h1 { max-width: 850px; font-size: clamp(3.1rem, 7vw, 7.4rem); line-height: .98; color: #f1f4e9; } h1 em { color: #c9f45a; font-style: normal; }
  .dek { max-width: 650px; margin: 28px 0 0; color: #89968e; font-size: 1rem; line-height: 1.9; }
  .hero-stamp { display: grid; grid-template-columns: 70px 1fr; align-content: center; gap: 18px 14px; padding: 20px 0 20px 22px; border-left: 1px solid #3b493e; }
  .stamp-ring { grid-row: span 3; display: grid; align-content: center; justify-items: center; width: 68px; height: 68px; border: 1px solid #c9f45a; border-radius: 50%; color: #c9f45a; font-family: "IBM Plex Mono", monospace; } .stamp-ring span { font-size: .65rem; } .stamp-ring strong { font-size: 1.45rem; }
  .micro { display: block; margin-bottom: 6px; color: #65746a; font-size: .58rem; } .hero-stamp b { display: block; font: 600 .78rem "IBM Plex Mono", monospace; color: #e6eadf; } .hero-stamp .state { color: #c9f45a; }
  .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: 1px solid #27312e; } .kpi { min-height: 160px; padding: 24px 20px 20px 0; border-right: 1px solid #27312e; } .kpi:not(:first-child) { padding-left: 20px; } .kpi:last-child { border-right: 0; }
  .kpi span { display: block; min-height: 32px; color: #728078; font-size: .58rem; line-height: 1.5; } .kpi strong { display: block; margin: 18px 0 8px; color: #f0f3e9; font: 500 clamp(1.65rem, 3vw, 2.5rem) "IBM Plex Mono", monospace; letter-spacing: -.08em; } .kpi-accent strong { color: #c9f45a; } .kpi small { color: #69776e; font-size: .71rem; }
  .signal-strip { display: grid; grid-template-columns: 240px 1fr auto; gap: 20px; align-items: center; margin: 35px 0 70px; padding: 17px 20px; border: 1px solid #5d713b; background: linear-gradient(90deg, rgb(201 244 90 / .08), transparent 55%); } .signal-led { display: flex; align-items: center; gap: 12px; } .signal-mark { display: grid; place-items: center; width: 28px; height: 28px; border: 1px solid #c9f45a; border-radius: 50%; color: #c9f45a; font-weight: 800; } .signal-led strong { display: block; color: #c9f45a; font-family: "Noto Serif JP", serif; } .signal-strip p { margin: 0; color: #a1afa5; font-size: .84rem; line-height: 1.6; } .confidence { color: #c9f45a; font: .68rem "IBM Plex Mono", monospace; white-space: nowrap; }
  .section-block { margin: 0 0 80px; } .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 18px; margin-bottom: 25px; } .section-heading.compact { margin-bottom: 18px; } .section-heading h2, .method-intro h2 { font-size: clamp(2rem, 4vw, 3.6rem); line-height: 1; } .section-meta { color: #68766d; font-size: .62rem; }
  .filterbar { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 6px; } .filter { border: 1px solid #455343; padding: 10px 14px; background: transparent; color: #9aa79e; font: .63rem "IBM Plex Mono", monospace; cursor: pointer; } .filter.active, .filter:hover { border-color: #c9f45a; color: #c9f45a; }
  .scenario-frame { border-top: 1px solid #38443c; } .axis { display: grid; grid-template-columns: repeat(4, 1fr); padding: 9px 245px 10px 214px; color: #58665c; font-size: .56rem; } .axis span:not(:first-child) { text-align: right; }
  .scenario-row { display: grid; grid-template-columns: 194px 1fr 225px; gap: 20px; align-items: center; min-height: 89px; border-top: 1px solid #27312e; transition: opacity .2s; } .scenario-row[hidden] { display: none; } .scenario-name { display: flex; align-items: center; gap: 10px; } .scenario-pin { width: 9px; height: 9px; border-radius: 50%; background: #87948b; } .bull .scenario-pin { background: #c9f45a; box-shadow: 0 0 12px #c9f45a; } .bear .scenario-pin { background: #ed9b56; } .stress .scenario-pin { background: #e45d66; }
  .scenario-name b { color: #e6eadf; font: 600 .82rem "IBM Plex Mono", monospace; } .scenario-name small { display: block; margin-left: auto; color: #6e7b72; font: .64rem "IBM Plex Mono", monospace; } .range-track { position: relative; height: 20px; background: repeating-linear-gradient(90deg, #202b25 0 1px, transparent 1px 20%); } .zero-line { position: absolute; left: 24%; top: -5px; bottom: -5px; width: 1px; background: #667268; } .range-bar { position: absolute; top: 6px; height: 8px; min-width: 4px; background: #7b8b7e; } .bull .range-bar { background: #c9f45a; } .bear .range-bar { background: #ed9b56; } .stress .range-bar { background: #e45d66; }
  .scenario-values { display: grid; grid-template-columns: 1fr auto; align-items: baseline; gap: 0 10px; } .scenario-values strong { color: #e9eee3; font: 600 .98rem "IBM Plex Mono", monospace; } .scenario-values small { color: #6f7e73; font: .57rem "IBM Plex Mono", monospace; } .scenario-values span { grid-column: 1 / -1; margin-top: 5px; color: #78867c; font: .65rem "IBM Plex Mono", monospace; }
  .target-note { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-top: 20px; padding: 13px 15px; border-left: 2px solid #c9f45a; background: #121914; color: #78867c; font-size: .6rem; } .target-note b { color: #c9f45a; font-size: .68rem; }
  .evidence-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; } .evidence-card { min-height: 184px; padding: 17px; border: 1px solid #2b3830; background: #101512; } .evidence-top { display: flex; align-items: center; gap: 9px; } .source-index { color: #59665c; font: .65rem "IBM Plex Mono", monospace; } .evidence-top h3 { flex: 1; margin: 0; font: 600 1rem "Noto Serif JP", serif; } .evidence-top a { color: #a6b199; font: .6rem "IBM Plex Mono", monospace; text-decoration: none; } .evidence-top a:hover { color: #c9f45a; }
  .evidence-numbers { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 29px 0 19px; } .evidence-numbers span { display: block; color: #647269; font-size: .55rem; } .evidence-numbers strong { display: block; margin-top: 7px; color: #e7ede0; font: 600 1.08rem "IBM Plex Mono", monospace; } .evidence-card p { margin: 0; padding-top: 11px; border-top: 1px solid #29352e; color: #78867c; font: .61rem "IBM Plex Mono", monospace; } .definition-dot { display: inline-block; width: 6px; height: 6px; margin-right: 7px; border-radius: 50%; background: #ed9b56; }
  .evidence-total { display: grid; grid-template-columns: 1fr auto 1fr auto 1.3fr; align-items: center; gap: 18px; margin-top: 10px; padding: 23px 18px; border: 1px solid #4b5b47; background: #161d17; } .evidence-total strong { display: block; color: #e6eadf; font: 600 1.25rem "IBM Plex Mono", monospace; } .evidence-total small { color: #89968e; font-size: .7rem; } .math-sign { color: #627063; font: 1.3rem "IBM Plex Mono", monospace; } .total-result strong { color: #c9f45a; } .footnote { margin: 12px 0 0; color: #59665c; font-size: .58rem; line-height: 1.7; }
  .audit-grid { margin: 0 0 80px; padding: 25px 0 0; border-top: 1px solid #27312e; } .finding-list { display: grid; gap: 8px; } .finding { display: grid; grid-template-columns: 75px 1fr 9px; gap: 15px; align-items: center; padding: 14px 0; border-bottom: 1px solid #27312e; } .severity { align-self: start; padding-top: 2px; color: #ed9b56; font: .57rem "IBM Plex Mono", monospace; } .severity.critical { color: #e45d66; } .finding b { color: #dce3d9; font: 600 .78rem "IBM Plex Mono", monospace; } .finding p { margin: 5px 0 0; color: #77857b; font-size: .75rem; } .open-dot { width: 8px; height: 8px; border: 1px solid #e45d66; border-radius: 50%; }
  .method-grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: 60px; padding: 45px 0; border-top: 1px solid #27312e; } .method-intro p:not(.eyebrow) { max-width: 470px; margin: 22px 0; color: #89968e; line-height: 1.8; font-size: .84rem; } .text-link { color: #c9f45a; font: .62rem "IBM Plex Mono", monospace; text-decoration: none; } .formula-card { display: grid; gap: 16px; align-content: center; padding: 25px; border: 1px solid #344238; background: #101512; } .formula-card code { display: block; color: #dfe8d8; font: clamp(.8rem, 1.6vw, 1.1rem) "IBM Plex Mono", monospace; } .formula-card code::first-letter { color: #c9f45a; } .protocol { display: grid; gap: 7px; margin-top: 15px; padding-top: 15px; border-top: 1px solid #2b3830; } .protocol span { color: #6c7a70; font-size: .55rem; } .protocol b { color: #c9f45a; font: .7rem "IBM Plex Mono", monospace; line-height: 1.6; }
  .footer { display: flex; justify-content: space-between; gap: 18px; padding-top: 20px; border-top: 1px solid #27312e; color: #59665c; font-size: .56rem; }
  @media (max-width: 900px) { .hero { grid-template-columns: 1fr; } .hero-stamp { grid-template-columns: 65px 1fr 1fr; border-left: 0; border-top: 1px solid #3b493e; padding: 20px 0 0; } .stamp-ring { grid-row: span 2; } .kpi-grid { grid-template-columns: repeat(2, 1fr); } .kpi:nth-child(2) { border-right: 0; } .evidence-grid { grid-template-columns: repeat(2, 1fr); } .method-grid { grid-template-columns: 1fr; gap: 30px; } }
  @media (max-width: 620px) { .shell { width: min(100% - 26px, 1320px); } nav { gap: 10px; } nav a { font-size: .55rem; } .hero { padding: 65px 0 45px; } h1 { font-size: clamp(2.65rem, 14vw, 4.2rem); } .hero-stamp { grid-template-columns: 60px 1fr 1fr; } .signal-strip { grid-template-columns: 1fr; gap: 12px; } .confidence { justify-self: start; } .section-heading { align-items: start; flex-direction: column; } .axis { display: none; } .scenario-row { grid-template-columns: 1fr; gap: 9px; padding: 18px 0; } .range-track { order: 3; } .scenario-values { position: absolute; right: 13px; margin-top: -55px; } .scenario-name small { margin-left: 0; } .evidence-grid { grid-template-columns: 1fr; } .evidence-total { grid-template-columns: 1fr auto 1fr; gap: 12px; } .total-result { grid-column: 1 / -1; padding-top: 14px; border-top: 1px solid #344238; } .footer { flex-direction: column; gap: 8px; } }
</style>
