---
import fs from 'node:fs';
import path from 'node:path';
import '../styles/earnings.css';

const root = process.cwd().endsWith('site') ? path.resolve(process.cwd(), '..') : process.cwd();
const model = JSON.parse(fs.readFileSync(path.join(root, 'site/public/data/quant-audit.json'), 'utf8'));
const primaryApi = JSON.parse(fs.readFileSync(path.join(root, 'site/public/api/v1/index.json'), 'utf8'));
const snapshot = model.snapshot;
const normalized = model.normalized;
const sources = snapshot.sources;
const base = import.meta.env.BASE_URL;
const buildSha = import.meta.env.PUBLIC_BUILD_SHA;
if (!buildSha) throw new Error('PUBLIC_BUILD_SHA is required for provenance');

const usdB = (value) => `$${(Number(value) / 1_000_000_000).toFixed(3)}B`;
const okuUsd = (value) => `${(Number(value) / 100_000_000).toLocaleString('ja-JP', { maximumFractionDigits: 1 })}億ドル`;
const dateJa = (value) => {
  const [year, month, day] = value.slice(0, 10).split('-').map(Number);
  return `${year}年${month}月${day}日`;
};
const dateTimeJa = (value) => {
  const normalizedValue = value.replace('Z', '+00:00');
  const date = new Date(normalizedValue);
  return new Intl.DateTimeFormat('ja-JP', {
    timeZone: 'Asia/Tokyo',
    year: 'numeric',
    month: 'numeric',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
};
const periodJa = `${dateJa(snapshot.primary_period.start)}〜${dateJa(snapshot.primary_period.end)}`;
const cohortIds = new Set(sources.map((source) => source.id));
const totalFacts = primaryApi.companies.reduce((total, company) => total + company.facts.length, 0);
const capexGroups = Object.entries(normalized.capital_expenditures_by_fact_tag_usd);
const findings = model.audit.findings;

const sourceFor = (source, kind) =>
  kind === 'operating_cash_flow' ? source.operating_cash_flow_source_url : source.capital_expenditures_source_url;
const factFor = (source, kind) =>
  kind === 'operating_cash_flow' ? source.operating_cash_flow_fact_tag : source.capital_expenditures_fact_tag;
const difference = (source) => Number(source.operating_cash_flow_usd) - Number(source.capital_expenditures_usd);
const differenceText = (source) =>
  difference(source) >= 0
    ? `営業CFが設備投資を ${okuUsd(difference(source))} 上回る`
    : `設備投資が営業CFを ${okuUsd(Math.abs(difference(source)))} 上回る`;

const statusLabel = {
  reported_facts_same_period: '同じ四半期の2項目あり',
  public_no_10q_facts_yet: '10-Qの数値を待機中',
  public_no_quarterly_10q_facts: '四半期の数値なし',
  capital_expenditure_fact_unavailable: '設備投資の数値なし',
  operating_cash_flow_fact_unavailable: '営業CFの数値なし',
  reported_facts_period_mismatch: '期間が一致しない',
  excluded_without_estimate: '非公開企業のため数値なし',
};
const statusHelp = {
  reported_facts_same_period: '営業CFと設備投資を同じ四半期で確認できました。',
  public_no_10q_facts_yet: '公開企業ですが、対象となる四半期報告書の数値がまだありません。',
  public_no_quarterly_10q_facts: '四半期単独の数値を確認できませんでした。',
  capital_expenditure_fact_unavailable: '営業CFはありますが、登録した設備投資タグの数値がありません。',
  operating_cash_flow_fact_unavailable: '設備投資はありますが、営業CFの数値がありません。',
  reported_facts_period_mismatch: '2項目はありますが、集計対象の四半期と期間が一致しません。',
  excluded_without_estimate: '推定値を作らず、欠測のまま表示しています。',
};
const roleLabel = {
  hyperscaler: '大手クラウド',
  'cloud-provider': 'クラウド',
  'ai-cloud': 'AIクラウド',
  'data-center-operator': 'データセンター',
  'model-lab': 'AI開発企業',
  'aerospace-and-infrastructure': '宇宙・インフラ',
};
const findingLabel = {
  capital_expenditure_concepts_not_comparable: {
    title: '設備投資の定義が2種類あります',
    detail: '会社が使うXBRLタグが異なるため、設備投資の総額や全社合計の差額は表示していません。',
  },
};
for (const company of primaryApi.companies) {
  if (!(company.quantitative_status in statusLabel)) {
    throw new Error(`Unknown quantitative status: ${company.quantitative_status}`);
  }
}
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="大手テック企業の営業キャッシュフローと設備投資を、SEC提出書類の一次情報だけで確認できるダッシュボード。"
    />
    <title>大手テック企業の現金と設備投資｜SEC一次情報</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">本文へ移動</a>

    <header class="site-header">
      <a class="brand" href={base} aria-label="トップページへ">
        <span class="brand-mark" aria-hidden="true">✓</span>
        <span>一次情報ダッシュボード</span>
      </a>
      <nav aria-label="ページ内メニュー">
        <a href="#summary">要点</a>
        <a href="#companies">企業別</a>
        <a href="#coverage">対象範囲</a>
        <a href="#method">しくみ</a>
      </nav>
    </header>

    <main id="main-content">
      <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="kicker">SEC提出書類だけを使用・推定値なし</p>
          <h1 id="page-title">大手テック企業は、<br /><em>いくら現金を生み、設備に使ったか。</em></h1>
          <p class="hero-lede">
            {periodJa}の営業キャッシュフローと設備投資を、企業ごとに同じ期間で確認します。
            将来予測や投資判断ではなく、報告済みの事実を確かめるページです。
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#companies">企業別の数字を見る</a>
            <a class="button secondary" href="#method">集計方法を確認する</a>
          </div>
        </div>

        <aside class="answer-card" aria-label="このページの結論">
          <span class="answer-label">最初に分かること</span>
          <strong>{sources.length}社の営業CF合計は<br />{okuUsd(normalized.operating_cash_flow_total_usd)}</strong>
          <small>{usdB(normalized.operating_cash_flow_total_usd)}</small>
          <p>
            設備投資はXBRL上の定義が{normalized.capital_expenditures_fact_tag_count}種類あるため、
            全社合計や「残った現金」の総額にはまとめていません。
          </p>
        </aside>
      </section>

      <section id="summary" class="summary" aria-labelledby="summary-title">
        <div class="section-heading compact">
          <p class="section-number">01</p>
          <div>
            <h2 id="summary-title">30秒で分かる要点</h2>
            <p>このページで分かることと、分からないことを先に分けます。</p>
          </div>
        </div>

        <div class="boundary-grid">
          <article class="boundary-card can">
            <span aria-hidden="true">✓</span>
            <div>
              <h3>分かること</h3>
              <p>企業ごとの営業CF、設備投資、対象期間、SEC提出書類、XBRLタグ。</p>
            </div>
          </article>
          <article class="boundary-card cannot">
            <span aria-hidden="true">—</span>
            <div>
              <h3>このページでは答えないこと</h3>
              <p>将来の半導体利益、業界全体の設備投資額、株価予想、投資推奨。</p>
            </div>
          </article>
        </div>

        <div class="metric-grid" aria-label="データ概要">
          <article>
            <span>登録企業</span>
            <strong>{primaryApi.companies.length}社</strong>
            <small>公開・非公開を含む</small>
          </article>
          <article>
            <span>比較できる企業</span>
            <strong>{sources.length}社</strong>
            <small>同じ四半期の2項目あり</small>
          </article>
          <article>
            <span>確認した一次データ</span>
            <strong>{totalFacts}件</strong>
            <small>SEC Companyfacts</small>
          </article>
          <article>
            <span>設備投資の定義</span>
            <strong>{normalized.capital_expenditures_fact_tag_count}種類</strong>
            <small>混ぜずに分けて表示</small>
          </article>
        </div>
      </section>

      <section id="companies" class="section" aria-labelledby="companies-title">
        <div class="section-heading">
          <p class="section-number">02</p>
          <div>
            <h2 id="companies-title">企業別の数字</h2>
            <p>金額は「億ドル」を主表示にし、元のUSD表記も併記しています。</p>
          </div>
        </div>

        <div class="company-grid">
          {sources.map((source) => (
            <article class="company-card">
              <header>
                <div>
                  <span class="ticker">{source.ticker}</span>
                  <h3>{source.label}</h3>
                </div>
                <a
                  class="source-button"
                  href={sourceFor(source, 'operating_cash_flow')}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={`${source.label}のSEC提出書類を開く`}
                >
                  SEC提出書類 ↗
                </a>
              </header>

              <p class="period">{dateJa(source.period_start)}〜{dateJa(source.period_end)}</p>

              <div class="cash-grid">
                <div>
                  <span class="metric-label">営業キャッシュフロー</span>
                  <strong>{okuUsd(source.operating_cash_flow_usd)}</strong>
                  <small>{usdB(source.operating_cash_flow_usd)}・本業で生んだ現金</small>
                </div>
                <div>
                  <span class="metric-label">報告された設備投資</span>
                  <strong>{okuUsd(source.capital_expenditures_usd)}</strong>
                  <small>{usdB(source.capital_expenditures_usd)}・会社の報告タグに基づく</small>
                </div>
              </div>

              <div class:list={['difference', difference(source) >= 0 ? 'positive' : 'negative']}>
                <span>単純差額</span>
                <strong>{differenceText(source)}</strong>
                <small>営業CF − 設備投資。フリーキャッシュフローとは呼びません。</small>
              </div>

              <details>
                <summary>数字の定義と取得元を見る</summary>
                <dl>
                  <div>
                    <dt>営業CFのXBRLタグ</dt>
                    <dd><code>{factFor(source, 'operating_cash_flow')}</code></dd>
                  </div>
                  <div>
                    <dt>設備投資のXBRLタグ</dt>
                    <dd><code>{factFor(source, 'capital_expenditures')}</code></dd>
                  </div>
                  <div>
                    <dt>データ取得元</dt>
                    <dd><a href={source.source_api_url} target="_blank" rel="noreferrer">SEC Companyfacts API ↗</a></dd>
                  </div>
                </dl>
              </details>
            </article>
          ))}
        </div>
      </section>

      <section class="section definition-section" aria-labelledby="definition-title">
        <div class="section-heading">
          <p class="section-number">03</p>
          <div>
            <h2 id="definition-title">なぜ設備投資を全社合計しないのか</h2>
            <p>同じ「設備投資」に見えても、提出書類上の定義が一致しないためです。</p>
          </div>
        </div>

        <div class="definition-layout">
          <div class="plain-explanation">
            <strong>数字を大きく見せるために、違う定義を足しません。</strong>
            <p>
              営業CFは全社で同じXBRLタグですが、設備投資は
              <code>PaymentsToAcquireProductiveAssets</code> と
              <code>PaymentsToAcquirePropertyPlantAndEquipment</code> に分かれます。
              そのため、タグ別の合計だけを示します。
            </p>
          </div>

          <div class="tag-groups" aria-label="設備投資のタグ別集計">
            {capexGroups.map(([tag, value]) => (
              <article>
                <code>{tag}</code>
                <strong>{okuUsd(value)}</strong>
                <small>{usdB(value)}</small>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="coverage" class="section" aria-labelledby="coverage-title">
        <div class="section-heading">
          <p class="section-number">04</p>
          <div>
            <h2 id="coverage-title">どの企業を確認できたか</h2>
            <p>取れなかった数字をゼロにせず、「なぜ取れないか」を表示します。</p>
          </div>
        </div>

        <div class="coverage-list">
          {primaryApi.companies.map((company) => (
            <article class:list={['coverage-item', cohortIds.has(company.id) ? 'included' : 'missing']}>
              <div class="coverage-company">
                <strong>{company.name}</strong>
                {company.product_aliases ? <small>{company.product_aliases.join(', ')}</small> : null}
              </div>
              <div class="coverage-role">{roleLabel[company.role] ?? company.role}</div>
              <div class="coverage-status">
                <span>{cohortIds.has(company.id) ? '比較対象' : statusLabel[company.quantitative_status]}</span>
                <small>
                  {cohortIds.has(company.id)
                    ? '営業CFと設備投資を同じ四半期で確認済み。'
                    : statusHelp[company.quantitative_status]}
                </small>
              </div>
              <div class="coverage-source">
                {company.recent_filings && company.recent_filings.length > 0 ? (
                  <a
                    href={company.recent_filings[0].source_url}
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`${company.name}の最新提出書類を開く`}
                  >
                    {company.recent_filings[0].form}・{dateJa(company.recent_filings[0].filed)} ↗
                  </a>
                ) : (
                  <span>公開提出書類なし</span>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="method" class="section method-section" aria-labelledby="method-title">
        <div class="section-heading">
          <p class="section-number">05</p>
          <div>
            <h2 id="method-title">このページができるまで</h2>
            <p>自動更新でも、比較条件を満たさない数字は公開集計へ入れません。</p>
          </div>
        </div>

        <ol class="steps">
          <li>
            <span>1</span>
            <div><strong>SECから取得</strong><p>各社のCompanyfacts APIと提出書類を取得します。</p></div>
          </li>
          <li>
            <span>2</span>
            <div><strong>期間をそろえる</strong><p>開始日と終了日が一致する四半期だけを選びます。</p></div>
          </li>
          <li>
            <span>3</span>
            <div><strong>2項目を確認</strong><p>営業CFと登録済みの設備投資タグが両方ある企業だけを比較します。</p></div>
          </li>
          <li>
            <span>4</span>
            <div><strong>異なる定義を分離</strong><p>設備投資タグが異なる場合は、全社合計を作りません。</p></div>
          </li>
        </ol>

        <div class="audit-box">
          <div>
            <span class="audit-state">監査状態</span>
            <strong>{findings.length ? `制約つきで観測済み・確認事項 ${findings.length}件` : '確認事項なし'}</strong>
          </div>
          {findings.length ? (
            <div class="finding-list">
              {findings.map((finding) => {
                const translated = findingLabel[finding.id];
                return (
                  <article>
                    <span>{finding.severity === 'major' ? '重要' : finding.severity}</span>
                    <div>
                      <strong>{translated?.title ?? finding.id.replaceAll('_', ' ')}</strong>
                      <p>{translated?.detail ?? finding.detail}</p>
                    </div>
                  </article>
                );
              })}
            </div>
          ) : (
            <p>入力条件と一次資料の必須項目を確認済みです。</p>
          )}
        </div>

        <details class="technical-details">
          <summary>更新日時・ハッシュ・選択ルールを見る</summary>
          <dl>
            <div><dt>対象期間</dt><dd>{periodJa}</dd></div>
            <div><dt>API取得日時</dt><dd>{dateTimeJa(snapshot.primary_api_generated_at)} JST</dd></div>
            <div><dt>スナップショット日時</dt><dd>{dateTimeJa(snapshot.as_of)} JST</dd></div>
            <div><dt>グラフ</dt><dd>{model.audit.graph_version}</dd></div>
            <div><dt>ビルドSHA</dt><dd data-build-sha={buildSha}><code>{buildSha}</code></dd></div>
            <div><dt>APIハッシュ</dt><dd><code>{snapshot.primary_api_content_hash}</code></dd></div>
            <div><dt>スナップショットハッシュ</dt><dd data-snapshot-hash={model.snapshot_hash}><code>{model.snapshot_hash}</code></dd></div>
            <div><dt>選択ルール</dt><dd>{snapshot.selection_rule}</dd></div>
          </dl>
        </details>

        <div class="data-links">
          <a href={base + 'api/v1/index.json'}>企業APIを見る ↗</a>
          <a href={base + 'api/v1/facts.json'}>全factを見る ↗</a>
          <a href={base + 'data/quant-audit.json'}>監査JSONを見る ↗</a>
        </div>
      </section>
    </main>

    <footer>
      <p>出所: SEC EDGAR Companyfacts / 10-Q</p>
      <p>推定値なし・投資助言ではありません</p>
    </footer>
  </body>
</html>
