  .formula-grid, .unknown-grid, .output-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; } .formula-grid article, .unknown-grid article { min-height: 170px; padding: 21px; border: 1px solid #cbcabe; background: #f8f6ef; } .formula-grid article span, .unknown-grid article b { color: #68766c; font: .58rem "IBM Plex Mono", monospace; letter-spacing: .08em; text-transform: uppercase; } code { display: block; margin: 20px 0 13px; color: #25372a; font: .9rem "IBM Plex Mono", monospace; line-height: 1.55; overflow-wrap: anywhere; } .formula-grid p, .unknown-grid p { margin: 0; color: #6a786e; font-size: .73rem; line-height: 1.7; } .formula-grid .example { color: #654d2f; background: #f1e5d0; } .formula-grid .example code { color: #684b28; font-size: .72rem; }
  .unknown-grid { grid-template-columns: repeat(3, 1fr); } .unknown-grid article { border-top: 3px solid #c5745f; } .unknown-grid p strong { color: #a16625; } .output-grid { grid-template-columns: repeat(3, 1fr); } .output-grid article { padding: 21px; background: #172d23; } .output-grid span { color: #b1c3ae; font-size: .55rem; } .output-grid strong { display: block; margin-top: 19px; color: #d7fa67; font: 600 1.8rem "IBM Plex Mono", monospace; } .output-grid p { margin: 8px 0 0; color: #b7c9b3; font-size: .7rem; line-height: 1.6; }
  .technical details { border-top: 1px solid #c9c6bc; border-bottom: 1px solid #c9c6bc; } .technical summary { display: flex; justify-content: space-between; gap: 20px; padding: 23px 0; cursor: pointer; list-style: none; } .technical summary::-webkit-details-marker { display: none; } .technical summary strong { display: block; color: #25372a; font: 1.45rem "Hiragino Mincho ProN", serif; } .open-mark { color: #728b00; font: 1.1rem "IBM Plex Mono", monospace; } .technical-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; padding-bottom: 24px; background: #d3d2c9; } .technical-grid > div { display: grid; gap: 10px; padding: 15px; background: #e9e7dd; } .technical-grid span { color: #818b82; font: .54rem "IBM Plex Mono", monospace; letter-spacing: .08em; text-transform: uppercase; } .technical-grid strong, .technical-grid a { color: #52625a; font: .62rem "IBM Plex Mono", monospace; overflow-wrap: anywhere; } .technical-grid a { color: #687d00; text-decoration: none; } footer { display: flex; justify-content: space-between; gap: 20px; padding-top: 18px; color: #879087; border-top: 1px solid #c9c6bc; font-size: .55rem; }
  @media (max-width: 860px) { .hero { grid-template-columns: 1fr; gap: 38px; } .hero-card { max-width: 340px; } .flow-grid { grid-template-columns: repeat(2, 1fr); } .flow-grid i { display: none; } .verdict-box { grid-template-columns: 1fr; gap: 18px; } .cohort-grid, .formula-grid, .unknown-grid, .output-grid, .watch-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .page { width: calc(100% - 28px); } .topbar { min-height: 64px; } .brand-sub { display: none; } nav { gap: 12px; } nav a { font-size: .54rem; } .hero { padding: 60px 0 70px; } h1 { max-width: 100%; font-size: clamp(1.65rem, 8.5vw, 3.5rem); line-height: 1.12; } .hero-lede { font-size: .82rem; } .hero-actions { flex-wrap: wrap; } .section-block { margin-bottom: 75px; } .section-heading { align-items: start; flex-direction: column; gap: 14px; } h2 { font-size: clamp(2.3rem, 12vw, 4rem); } .flow-grid, .cohort-grid, .formula-grid, .unknown-grid, .output-grid, .watch-grid { grid-template-columns: 1fr; } .input-row { grid-template-columns: 1.25fr repeat(4, minmax(0, 1fr)); font-size: .48rem; } .input-row b { font-size: .62rem; } .verdict-box { padding: 20px; } .technical-grid { grid-template-columns: 1fr; } footer { flex-direction: column; } }
</style>
